%
% v3.18: Fix ghost narrowing via page-eject (Task 166).
%   BUG: When a wrapped paragraph is long enough to span a page break,
%   TeX distributes the N narrowed parshape lines across pages. The
%   figure overlay (\smash{\rlap{...}}) is page-local, so continuation
%   lines on the next page are narrowed without a figure beside them.
%   4 instances in 50-figure stress test (42 pages).
%   FIX: In the NORMAL path (figure fits on current page), add a
%   page-eject check: if nl * baselineskip > remaining_space -
%   2*baselineskip, insert \newpage before setting \parshape and
%   placing the figure. This ensures all N narrow lines and the
%   figure are on the same page. Restructured code so \noindent
%   and \parshape are set AFTER the eject decision (not before),
%   preventing mode conflicts. Result: ghost narrowing 4 -> 0.
%
% v3.17: Fix itemize/enumerate parshape leak (Task 166).
%   BUG: LaTeX's \trivlist (called by all standard list environments)
%   resets \parshape to full width when a list starts. List items after
%   \swarmwrapnext flow at full page width through the figure, causing
%   body-text overlaps. 72 overlaps on 12 pages in 1000-page stress test.
%   FIX: Patch \list to re-apply parshape with remaining narrow lines
%   after \trivlist has reset it. Track remaining narrow lines via
%   \swarmwrap@remaining@nl counter, decremented by post_linebreak_filter
%   after each paragraph. Recompute tw relative to list's \linewidth
%   (lists have narrower \linewidth due to \leftmargin). Inject into
%   \everypar so subsequent \item paragraphs also get narrowing.
%
% v3.16: Make text-figure gap configurable via \swarmwrapgap{<dimen>}.
%   Previously the gap was hardcoded as 14pt in three places (text width
%   computation, inline figure placement, deferred figure placement).
%   Now users can set \swarmwrapgap{20pt} for wider spacing or
%   \swarmwrapgap{8pt} for tighter wrapping. Default remains 14pt for
%   backward compatibility. No behavioral changes with default value.
%
% v3.15: Fix emergencystretch leak into subsequent paragraphs.
%   BUG: \emergencystretch=\fontdimen6\font (~5pt) was set inside
%   \swarmwrapnext at document level (no surrounding group). After
%   the wrapped paragraph's line breaking completed, this value leaked
%   into all subsequent non-wrapped paragraphs, causing slightly
%   looser typesetting throughout the rest of the document.
%   FIX: Reset \emergencystretch to 0pt in post_linebreak_filter
%   after processing a wrapped paragraph (tw_sp > 0). The emergency
%   stretch has already been consumed during line breaking, so
%   resetting it afterward is safe. No regressions.
%
% v3.14: Force paragraph break + remaining-height vspace in \swarmwrapnext.
%   ROOT CAUSE: \noindent does not end the current paragraph when called
%   mid-paragraph. Consecutive swarmwrap blocks without blank lines merged
%   into ONE paragraph; only the FIRST figure's parshape applied.
%   FIX (two parts):
%   (1) Add \par at start of \swarmwrapnext to force paragraph break.
%       Each figure now gets its own paragraph with correct parshape.
%   (2) Track figure height remaining after paragraph ends via
%       post_linebreak_filter (compares total lines vs nl). Inject
%       \vspace{remaining} at next \swarmwrapnext to push subsequent
%       content below the previous figure, preventing overlap.
%   RESULT: 43 body-text overlaps -> 0 on 50-figure stress test.
%   4 FIGURE BESIDE TEXT -> 0. 42 pages, 0 errors. No regressions
%   on standard tests (customwrap, consecutive, pagebreak).
%   Removed v3.12 multi-paragraph extension (135 lines of FIFO queue,
%   everypar injection, remaining counter). v3.12 halved overlaps (74->37)
%   but added significant complexity. Starting clean from v3.10.
%   v3.12's deferred tw@val overwriting bug fix preserved (bake tw as
%   literal dimension into \afterpage token list via tex.sprint).
%
% v3.39: Fix ghost-narrowing orphan pages (user report).
%   BUG: 31 pages (10.9%) in the 1000-figure stress test had a single
%   narrow-text line at the top with no figure beside it. These "ghost"
%   pages had ~2% fill — 1 orphan line from the previous figure's
%   paragraph, shipped when \swarmwrapnext's \par caused a page
%   overflow. The previous figure's parshape was still active, so
%   the orphan rendered at narrow width. The penalty fence (v3.33)
%   could not prevent this because TeX commits 1 line before seeing
%   the penalty, and the pre_shipping_filter ghost-fill code (v3.34)
%   was dead (callback fails to register due to format cache).
%   ROOT CAUSE: When \par ships a page in narrow mode, the last narrow
%   line orphans on the shipped page. The v3.33 narrow-line check
%   (nl * bs > remaining → DEFER) missed these cases because \par
%   resets \pagetotal, making remaining appear large.
%   FIX (three parts):
%   (1) Pre-\par \vfill: Before \par in \swarmwrapnext, if in narrow
%       mode AND page is nearly full (remaining < 2 baselineskips),
%       insert \vfill. This pushes the orphan to the bottom of the
%       shipped page, making it look intentional. It also causes TeX
%       to pack content more efficiently, reducing total pages
%       (285 → 255 on 1000-fig test).
%   (2) Safe page-eject: When nl * baselineskip > remaining but the
%       figure itself fits (not DEFERRED), eject to a fresh page
%       BEFORE setting parshape, with full state cleanup
%       (parshape reset, everypar clear, stack clear, tw@lua zero).
%       v3.18 tried page-eject but REGRESSED because it leaked
%       parshape state. v3.39 avoids the regression by cleaning up
%       before eject. This converts potential ghost pages into clean
%       page breaks with the figure on the new page.
%   (3) DEFERRED state cleanup: Before the DEFERRED \newpage, clear
%       parshape to full-width, clear everypar, clear the figure
%       stack, and zero remaining@nl/tw@lua. This prevents the
%       DEFERRED \newpage from shipping a page with leaked narrow
%       parshape from the previous figure.
%   RESULT: Ghost pages 31 → 0 on 1000-fig test, 1 → 0 on 50-fig.
%   Pages: 285 → 255 (better space utilization from \vfill packing).
%   Figures: 1000/1000 present, 0 errors, 0 regressions on standard
%   test suites (customwrap, pagebreak-variations, itemize-wrap).
%
% Earlier versions (v3.4-v3.10): Penalty system, deferred afterpage, height
%   padding, non-LuaLaTeX error, page-eject fallback. All superseded by
%   v3.14+ architecture. See git history for details.

\ProvidesPackage{swarmwrap}[2026/06/10 v3.47 fix continuation ghost narrowing]

\RequirePackage{graphicx}
\RequirePackage{ifluatex}
% afterpage no longer needed (v3.27 — deferred path uses \newpage instead)
% Need \makeatletter for \@listdepth check in everypar (v3.29)
\makeatletter

\newsavebox{\swarmwrap@box}
\newsavebox{\swarmwrap@scaledbox}
\newdimen\swarmwrap@fw
\newdimen\swarmwrap@fh
\newdimen\swarmwrap@tw
\newcount\swarmwrap@nl
\newcount\swarmwrap@loop@cnt
\newif\ifswarmwrap@luatex
\newif\ifswarmwrap@squeezed
\newif\ifswarmwrap@deferred
\newif\ifswarmwrap@ext@skip  % skip everypar on first paragraph

\ifluatex \swarmwrap@luatextrue \else \swarmwrap@luatexfalse \fi

% ── Multi-paragraph everypar extension (v3.29) ────────────────────
% Re-applies parshape to subsequent paragraphs after the first one.
% When remaining@nl > 0, builds a new parshape spec from remaining lines
% and applies it. When remaining@nl = 0, clears everypar to avoid overhead.
\newcommand{\swarmwrap@build@ext@pshape}{%
  \xdef\swarmwrap@pshape@ext{\the\numexpr\swarmwrap@remaining@nl+1\relax\space}%
  \swarmwrap@loop@cnt=\swarmwrap@remaining@nl
  \loop
    \xdef\swarmwrap@pshape@ext{\swarmwrap@pshape@ext 0pt \the\swarmwrap@tw@lua\space}%
    \advance\swarmwrap@loop@cnt by -1
  \ifnum\swarmwrap@loop@cnt>0 \repeat
  \xdef\swarmwrap@pshape@ext{\swarmwrap@pshape@ext 0pt \the\linewidth\space}%
}

\newcommand{\swarmwrap@apply@ext@pshape}{%
  \ifswarmwrap@ext@skip
    \global\swarmwrap@ext@skipfalse
  \else
    \ifnum\swarmwrap@remaining@nl>0\relax
      \ifdim\swarmwrap@tw@lua>0pt\relax
        % Skip parshape inside lists (\@listdepth > 0).
        % Lists get narrow lines from the list patch (linewidth reduction).
        % Applying parshape here conflicts with \item processing.
        \ifnum\@listdepth>0\relax
        \else
          % v3.40: Limit parshape to lines that fit on current page.
          % Without this, everypar sets narrow parshape for all
          % remaining@nl lines even when the page is nearly full.
          % TeX then places narrow lines on the NEXT page where
          % no figure exists — "continuation ghost narrowing".
          \dimen0=\pagegoal
          \advance\dimen0 by -\pagetotal
          \advance\dimen0 by -3\baselineskip\relax
          \ifdim\dimen0>0pt\relax
            \count255=\swarmwrap@remaining@nl
            \loop
              \advance\dimen0 by -\baselineskip
            \ifdim\dimen0>0pt\relax
                \ifnum\count255>1\relax
                  \advance\count255 by -1
                \fi
            \repeat
            \ifnum\count255<\swarmwrap@remaining@nl\relax
              \global\swarmwrap@remaining@nl=\count255\relax
            \fi
          \fi
          \swarmwrap@build@ext@pshape
          \parshape \swarmwrap@pshape@ext\relax
          \emergencystretch=\fontdimen6\font\relax
        \fi
      \fi
    \else
      \everypar{}%
    \fi
  \fi
}

\newcommand{\swarmwrap@fw@val}{0pt}
\newcommand{\swarmwrap@fh@val}{0pt}

% ── Gap control ─────────────────────────────────────────────────────
\newdimen\swarmwrap@gap
\swarmwrap@gap=14pt

\newcommand{\swarmwrapgap}[1]{%
  \swarmwrap@gap=#1\relax
}

% ── Squeeze-fit threshold control (v3.31) ──────────────────────────
% Users can tune when squeeze-fit activates vs deferred-NEWPAGE.
% \swarmwrapsqueeze: fraction of figure height that remaining space
%   must exceed (default 0.4 = 40%). Higher = more aggressive squeeze.
% \swarmwrapsqueezemin: minimum remaining space in absolute terms
%   (default 2\baselineskip). Prevents squeeze when almost no space.
\newcommand{\swarmwrap@squeeze@factor}{0.4}
\newcommand{\swarmwrap@squeeze@factor@str}{0.4}

\newcommand{\swarmwrapsqueeze}[1]{%
  \def\swarmwrap@squeeze@factor{#1}%
  \def\swarmwrap@squeeze@factor@str{#1}%
}

\newdimen\swarmwrap@squeezemin
\swarmwrap@squeezemin=2\baselineskip

\newcommand{\swarmwrapsqueezemin}[1]{%
  \swarmwrap@squeezemin=#1\relax
}

% ── Penalty control ──────────────────────────────────────────────────
\newcount\swarmwrap@penalty
\swarmwrap@penalty=10000

\newcommand{\swarmwrappenalty}[1]{%
  \swarmwrap@penalty=#1\relax
}

\newdimen\swarmwrap@tw@lua
\swarmwrap@tw@lua=0pt

\newdimen\swarmwrap@remaining
\swarmwrap@remaining=0pt

\newdimen\swarmwrap@saved@origtw
\swarmwrap@saved@origtw=0pt

% v3.41: Track previous figure's vertical extent for overlap prevention.
% When consecutive figures of different widths are stacked, the previous
% figure's visual bottom may extend below the current text position.
% We save the figure's y-start and height to compute needed vspace.
\newdimen\swarmwrap@fig@ystart
\swarmwrap@fig@ystart=0pt
\newdimen\swarmwrap@fig@height
\swarmwrap@fig@height=0pt

% ── Multi-paragraph parshape persistence (v3.17) ────────────────────
\newcount\swarmwrap@remaining@nl
\swarmwrap@remaining@nl=0

% ── List patch: reduce \linewidth inside lists (Task 166) ──────
% LaTeX's \list (latex.ltx:15868) sets \parshape \@ne \@totalleftmargin \linewidth,
% overriding any swarmwrap narrow parshape. Hooks (para/begin) fire but TeX reads
% the parshape at a later stage. SOLUTION: When a list starts during an active
% wrap (remaining@nl > 0), reduce \linewidth by the figure width + gap before
% calling the original \list. The list's \parshape then uses the reduced
% \linewidth, producing naturally narrow lines. The reduction is scoped to
% the list environment using TeX grouping.
\let\swarmwrap@old@list\list

\newif\ifswarmwrap@in@list
\swarmwrap@in@listfalse

% \renewcommand{\list}: When remaining@nl > 0, reduce \linewidth by
% figure width + gap so the list's parshape produces narrow lines.
% The list's own grouping (\begin{itemize}...\end{itemize}) scopes the change.
\newdimen\swarmwrap@saved@lw
\renewcommand{\list}[2]{%
  \ifnum\swarmwrap@remaining@nl>0\relax
    \ifdim\swarmwrap@tw@lua>0pt\relax
      \swarmwrap@saved@lw=\linewidth
      \advance\linewidth by -\swarmwrap@fw@val
      \advance\linewidth by -\swarmwrap@gap
      \ifdim\linewidth>0pt\relax
        \swarmwrap@in@listtrue
        % v3.29: Clear everypar inside lists to prevent \item conflicts.
        \everypar{}%
      \else
        \linewidth=\swarmwrap@saved@lw
      \fi
    \fi
  \fi
  \swarmwrap@old@list{#1}{#2}%
  \swarmwrap@in@listfalse
}

% ── Lua callback: pre_shipping_filter (v3.32, extended v3.34) ─────────
% v3.32: Detects page shipping to fix hollow carry-over (Task #172).
%   Sets a flag when TeX ships a page. \swarmwrapnext checks this
%   flag after \par to detect page overflow.
% v3.34: Zero remaining@nl and clear everypar on page shipping to
%   prevent cross-page multi-paragraph ghost narrowing. When a page
%   ships with remaining@nl > 0, the everypar hook would re-apply
%   narrow parshape to subsequent paragraphs on the NEXT page, even
%   though no figure exists there. By zeroing remaining@nl and clearing
%   everypar at ship time, the next page starts full-width.
%   This is NOT a page-eject (v3.18) — no \newpage, no layout change,
%   purely a state reset. Safe because: if the current page had a
%   figure, its narrow lines were already consumed by the paragraph
%   that triggered the page break; any remaining narrow capacity is
%   wasted anyway since the figure is page-local (\smash{\rlap}).
\ifswarmwrap@luatex
% Lua code below must NOT contain -- comments (TeX strips newlines
% inside \directlua{}, causing -- to eat all subsequent code).
\directlua{
  swarmwrap_page_shipped = false
  swarmwrap_fig_stack = {}
  swarmwrap_ghost_widen = false
  swarmwrap_ghost_tw = 0
  swarmwrap_safe_dimen = function(name)
    local ok, val = pcall(tex.dimen, name)
    if ok then return val end
    return 0
  end
  swarmwrap_safe_count = function(name)
    local ok, val = pcall(tex.count, name)
    if ok then return val end
    return 0
  end
  luatexbase.add_to_callback("buildpage_filter",
    function(head, groupcode)
      swarmwrap_page_shipped = true
      local rnl = swarmwrap_safe_count("swarmwrap@remaining@nl")
      local tw_lua = swarmwrap_safe_dimen("swarmwrap@tw@lua")
      if rnl > 0 and tw_lua > 0 then
        local page_used = swarmwrap_safe_dimen("pagetotal")
        local bs = swarmwrap_safe_dimen("baselineskip")
        if page_used > 0 and page_used < 3 * bs then
          local g1 = node.new("glue")
          g1.width = 0
          g1.stretch = 65536
          g1.stretch_order = 2
          local g2 = node.new("glue")
          g2.width = 0
          g2.stretch = 65536
          g2.stretch_order = 0
          node.insert_before(head, head, g1)
          node.insert_after(head, g1, g2)
          tex.dimen["swarmwrap@remaining"] = 0
        end
        tex.count["swarmwrap@remaining@nl"] = 0
        tex.toks["everypar"] = {}
      end
      swarmwrap_fig_stack = {}
      return head
    end, "swarmwrap: buildpage filter")
}
\fi

% ── Lua callback: post_linebreak_filter ───────────────────────────────
% This callback:
%   (a) v3.33 penalty fence: inserts penalties between consecutive narrow
%       lines to prevent page breaks within the narrow zone.
%   (b) v3.17 remaining-nl tracking: decrements remaining@nl counter.
%   (c) v3.19 cross-page fix: zeros remaining@nl if paragraph broke
%       across pages (total_lines < nl).
%   (d) v3.29 everypar clearing: clears everypar when remaining@nl = 0.
%   (e) v3.14 remaining height: computes vspace for next \swarmwrapnext.
%   (f) v3.15 emergencystretch reset: prevents leak to subsequent paragraphs.
%   (g) v3.6 boundary penalty: inserts penalty after last narrow line.
%   (h) v3.37 figure stack: pops exhausted figures and promotes next
%       entry so everypar continues with previous figure's parameters.
% IMPORTANT: Lua -- comments are FORBIDDEN inside \directlua{} blocks.
%   TeX strips newlines, causing -- to consume all subsequent code.
\ifswarmwrap@luatex
\directlua{
  function swarmwrap_post_lb(head, groupcode)
    if swarmwrap_ghost_widen then
      local lw_val = swarmwrap_safe_dimen("linewidth")
      local ghost_tw = swarmwrap_ghost_tw
      local tol = 3.0
      local narrow_max = (ghost_tw / 65536.0) + tol
      local current = head
      while current do
        if current.id == 0 then
          local lw = current.width / 65536.0
          if lw <= narrow_max and lw > 0 then
            current.width = lw_val
            local fil = node.new(node.id("glue"))
            fil.stretch = 65536
            fil.stretch_order = 2
            node.insert_after(head, current, fil)
          end
        end
        current = current.next
      end
      swarmwrap_ghost_widen = false
      swarmwrap_ghost_tw = 0
      return head
    end
    local tw_sp = swarmwrap_safe_dimen("swarmwrap@tw@lua")
    if tw_sp <= 0 then
      return head
    end
    local tw_val = tw_sp / 65536.0
    local tol = 3.0
    local narrow_width_max = tw_val + tol
    local last_narrow = nil
    local prev_narrow = nil
    local total_lines = 0
    local narrow_count = 0
    local penalty_val = swarmwrap_safe_count("swarmwrap@penalty")
    local current = head
    local narrow_nodes = {}
    while current do
      if current.id == 0 then
        total_lines = total_lines + 1
        local lw = current.width / 65536.0
        if lw <= narrow_width_max and lw > 0 then
          narrow_count = narrow_count + 1
          last_narrow = current
          narrow_nodes[#narrow_nodes + 1] = current
        end
      end
      current = current.next
    end
    if penalty_val > 0 and #narrow_nodes > 1 then
      for i = 1, #narrow_nodes - 1 do
        local p = node.new(node.id("penalty"))
        p.penalty = penalty_val
        node.insert_after(head, narrow_nodes[i], p)
      end
    end
    if swarmwrap_safe_count("swarmwrap@remaining@nl") > 0 then
      local r = swarmwrap_safe_count("swarmwrap@remaining@nl")
      local nl = swarmwrap_safe_count("swarmwrap@nl")
      if total_lines < nl then
        swarmwrap_ghost_widen = true
        swarmwrap_ghost_tw = tw_sp
        tex.count["swarmwrap@remaining@nl"] = 0
        swarmwrap_fig_stack = {}
        tex.toks["everypar"] = {}
      else
        r = math.max(0, r - narrow_count)
        tex.count["swarmwrap@remaining@nl"] = r
        local stack = swarmwrap_fig_stack
        if type(stack) ~= "table" then
          stack = {}
          swarmwrap_fig_stack = stack
        end
        if #stack > 0 then
          stack[#stack].remaining_nl = r
        end
      end
      if swarmwrap_safe_count("swarmwrap@remaining@nl") == 0 then
        local stack = swarmwrap_fig_stack
        if #stack > 1 then
          table.remove(stack)
          local prev = stack[#stack]
          tex.count["swarmwrap@remaining@nl"] = prev.remaining_nl
          tex.dimen["swarmwrap@tw@lua"] = prev.tw
          tex.count["swarmwrap@nl"] = prev.nl
          local min_tw = prev.tw
          for i = 1, #stack do
            if stack[i].tw > 0 and stack[i].tw < min_tw then
              min_tw = stack[i].tw
            end
          end
          if min_tw <= 0 then
            min_tw = prev.tw
          end
          tex.dimen["swarmwrap@tw@lua"] = min_tw
        else
          if #stack == 1 then
            table.remove(stack)
          end
          tex.toks["everypar"] = {}
        end
      end
    end
    local nl = swarmwrap_safe_count("swarmwrap@nl")
    local bs = swarmwrap_safe_dimen("baselineskip")
    local excess = 0
    if total_lines < nl then
      excess = (nl - total_lines) * bs
    end
    tex.dimen["swarmwrap@remaining"] = excess
    tex.dimen["emergencystretch"] = 0
    if penalty_val > 0 and last_narrow then
      local p = node.new(node.id("penalty"))
      p.penalty = penalty_val
      node.insert_after(head, last_narrow, p)
    end
    if penalty_val > 0 and swarmwrap_safe_count("swarmwrap@remaining@nl") > 0 then
      local last_node = head
      while last_node.next do
        last_node = last_node.next
      end
      local p = node.new(node.id("penalty"))
      p.penalty = penalty_val
      node.insert_after(head, last_node, p)
    end
    return head
  end
  luatexbase.add_to_callback("post_linebreak_filter",
    swarmwrap_post_lb, "swarmwrap: penalty at parshape boundary")
}
\fi

% ── Environment: capture content into a savebox ─────────────────────
\newenvironment{swarmwrap}{%
  \ifswarmwrap@luatex
    \begin{lrbox}{\swarmwrap@box}%
  \else
    \PackageError{swarmwrap}{LuaLaTeX required for wrapping}{}%
  \fi
}{%
  \ifswarmwrap@luatex
    \end{lrbox}%
    \global\setbox\swarmwrap@box=\box\swarmwrap@box
    \swarmwrap@fw=\wd\swarmwrap@box
    \xdef\swarmwrap@fw@val{\the\swarmwrap@fw}%
    \swarmwrap@fh=\ht\swarmwrap@box
    \advance\swarmwrap@fh by \dp\swarmwrap@box
    \advance\swarmwrap@fh by 4pt
    \xdef\swarmwrap@fh@val{\the\swarmwrap@fh}%
  \fi
}

% ── \swarmwrapnext: compute parshape and place figure ──────────────────
% v3.28: Three paths — NORMAL (fits), SQUEEZE-FIT (scaled to fit),
%   DEFERRED (\newpage). Squeeze-fit checks remaining space vs figure
%   height: if >= 50% and >= 3 baselineskip, scale figure via
%   \resizebox{!}{<remaining-4pt>}{...} to fit. Falls through to
%   DEFERRED only when remaining is too small.
\ifswarmwrap@luatex
\newcommand{\swarmwrapnext}{%
  % v3.39: If in narrow mode and page is nearly full, absorb the tail
  % gracefully before \par to avoid ghost-narrowing orphan pages.
  % When \par causes a page ship, TeX places the last narrow line on
  % the shipped page with no figure beside it. By detecting this
  % BEFORE \par, we can fill the page to push the orphan to the bottom.
  \ifnum\swarmwrap@remaining@nl>0\relax
    \ifdim\swarmwrap@tw@lua>0pt\relax
      \dimen0=\pagegoal
      \advance\dimen0 by -\pagetotal
      \ifdim\dimen0<2\baselineskip\relax
        \vfill
      \fi
    \fi
  \fi
  % v3.32: Clear page-shipped flag BEFORE \par to detect overflow
  \directlua{swarmwrap_page_shipped = false}%
  \par
  % v3.32: If \par caused a page overflow, discard remaining vspace.
  % The previous figure is on the previous page, so its tail
  % vspace is irrelevant here and would waste space on the fresh
  % page, potentially triggering unnecessary DEFERRED-NEWPAGE.
  \ifdim\swarmwrap@remaining>0pt\relax
    \directlua{
      if swarmwrap_page_shipped then
        tex.dimen["swarmwrap@remaining"] = 0
        tex.dimen["swarmwrap@fig@ystart"] = 0
        tex.dimen["swarmwrap@fig@height"] = 0
      end
    }%
  \fi
  \ifdim\swarmwrap@remaining>0pt
    \vspace{\swarmwrap@remaining}%
    \global\swarmwrap@remaining=0pt%
  \fi
  % v3.41: Direct vspace computation for figure overlap prevention.
  % The post_linebreak_filter callback has a bug that prevents it from
  % computing remaining height. As a fallback, compute needed vspace
  % directly: if the previous figure's visual bottom extends below the
  % current page position, add vspace to clear it.
  \ifdim\swarmwrap@fig@height>0pt\relax
    \ifdim\swarmwrap@fig@ystart>\pagetotal\relax
      \global\swarmwrap@fig@ystart=0pt\relax
      \global\swarmwrap@fig@height=0pt\relax
    \else
      \dimen0=\swarmwrap@fig@ystart
      \advance\dimen0 by \swarmwrap@fig@height
      \advance\dimen0 by -\pagetotal
      \ifdim\dimen0>0pt\relax
        \vspace{\dimen0}%
      \fi
    \fi
  \fi
  % Reset figure tracking (will be set again after placement).
  \global\swarmwrap@fig@ystart=0pt\relax
  \global\swarmwrap@fig@height=0pt\relax
  \swarmwrap@fw=\swarmwrap@fw@val\relax
  \swarmwrap@fh=\swarmwrap@fh@val\relax
  % ── Squeeze-fit check (v3.28/v3.31) ────────────────────────
  % When figure doesn't fit, check if scaling it down would allow
  % it to fit. Conditions: remaining >= squeeze-factor * fh AND
  % remaining >= squeezemin. Both thresholds user-configurable
  % via \swarmwrapsqueeze and \swarmwrapsqueezemin (v3.31).
  \swarmwrap@squeezedfalse
  \swarmwrap@deferredfalse
  \dimen0=\pagegoal
  \advance\dimen0 by -\pagetotal
  \ifdim\dimen0<\swarmwrap@fh
    % Figure doesn't fit. Try squeeze-fit.
    \dimen2=\swarmwrap@squeeze@factor\swarmwrap@fh
    \dimen3=\swarmwrap@squeezemin
    \ifdim\dimen0>\dimen2
      \ifdim\dimen0>\dimen3
        % SQUEEZE-FIT: Scale figure proportionally to fit.
        \advance\dimen0 by -4pt
        \setbox\swarmwrap@scaledbox=\hbox{\resizebox{!}{\dimen0}{\copy\swarmwrap@box}}%
        \swarmwrap@fw=\wd\swarmwrap@scaledbox
        \swarmwrap@fh=\ht\swarmwrap@scaledbox
        \advance\swarmwrap@fh by \dp\swarmwrap@scaledbox
        \advance\swarmwrap@fh by 4pt
        \swarmwrap@squeezedtrue
      \else
        \swarmwrap@deferredtrue
      \fi
    \else
      \swarmwrap@deferredtrue
    \fi
  \fi
  % ── Compute text width and parshape ─────────────────────────────
  % Uses squeeze-adjusted fw/fh when squeeze-fit was applied.
  \swarmwrap@tw=\linewidth
  \advance\swarmwrap@tw by -\swarmwrap@fw
  \advance\swarmwrap@tw by -\swarmwrap@gap
  \ifdim\swarmwrap@tw<0pt
    \swarmwrap@tw=0pt
  \fi
  \swarmwrap@nl=0
  \dimen0=\swarmwrap@fh
  \loop
    \advance\swarmwrap@nl by 1
    \advance\dimen0 by -\baselineskip
  \ifdim\dimen0>0pt \repeat
  \xdef\swarmwrap@tw@val{\the\swarmwrap@tw}%
  \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
  \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@nl+1\relax\space}%
  \swarmwrap@loop@cnt=\swarmwrap@nl
  \loop
    \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
    \advance\swarmwrap@loop@cnt by -1
  \ifnum\swarmwrap@loop@cnt>0 \repeat
  \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\linewidth\space}%
  % v3.39: Narrow-line space check with safe page-eject.
  % When the narrow parshape lines won't all fit on the current page
  % (nl * baselineskip > remaining), eject to a fresh page BEFORE
  % setting parshape. This prevents 1-line ghost orphan pages.
  % v3.18 tried this but REGRESSED because parshape leaked across
  % \newpage. v3.39 fixes the leak by explicitly resetting parshape
  % to full-width and running \par BEFORE the narrow parshape is set.
  % The sequence: \newpage → full-width parshape → \par → then
  % set narrow parshape and place figure on the clean page.
  \ifswarmwrap@deferred\else
    \ifswarmwrap@squeezed\else
      \dimen0=\pagegoal
      \advance\dimen0 by -\pagetotal
      \dimen2=\swarmwrap@nl\baselineskip
      \ifdim\dimen2>\dimen0
        \parshape 1 0pt \the\linewidth\relax
        \everypar{}%
        \directlua{swarmwrap_fig_stack = {}}%
        \global\swarmwrap@remaining@nl=0\relax
        \global\swarmwrap@tw@lua=0pt%
        \noindent\par
        \newpage
        \global\swarmwrap@remaining=0pt%
      \fi
    \fi
  \fi
  % v3.39: Split state setup — DEFERRED sets up AFTER \newpage.
  % In the DEFERRED path, parshape/everypar/stack must NOT be set before
  % \newpage because TeX's paragraph builder can render an orphan narrow
  % line on the about-to-be-shipped page (leaked parshape). Instead,
  % clear parshape before eject and set up state on the fresh page.
  % NORMAL/SQUEEZE-FIT set up immediately as before.
  \ifswarmwrap@deferred
    % DEFERRED: figure doesn't fit, squeeze not possible.
    % v3.36: Hollow carry-over fix.
    \ifdim\pagetotal<3\baselineskip\relax
      \vfill
      \wlog{swarmwrap next: HOLLOW-FILL --- pagetotal=\the\pagetotal}%
    \fi
    % Clear any leaked parshape from previous figures before eject.
    % This prevents orphan narrow lines on the shipped page.
    \parshape 1 0pt \the\linewidth\relax
    \everypar{}%
    \directlua{swarmwrap_fig_stack = {}}%
    \global\swarmwrap@remaining@nl=0\relax
    \newpage
    % Now set up parshape state on the fresh page (after eject).
    \global\swarmwrap@remaining@nl=\swarmwrap@nl
    \emergencystretch=\fontdimen6\font\relax
    \directlua{
      local stack = swarmwrap_fig_stack
      local tw_val = tex.dimen["swarmwrap@tw@lua"]
      local nl_val = tex.count["swarmwrap@nl"]
      table.insert(stack, {
        tw = tw_val,
        nl = nl_val,
        remaining_nl = nl_val
      })
    }%
    \swarmwrap@ext@skiptrue
    \ifnum\@listdepth=0\relax
      \everypar=\expandafter{\swarmwrap@apply@ext@pshape}%
    \fi
    \noindent
    \parshape \swarmwrap@pshape\relax
    \smash{\rlap{\hskip\swarmwrap@tw@val\hskip\swarmwrap@gap\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}}}%
    \wlog{swarmwrap next: DEFERRED-NEWPAGE --- fh=\the\swarmwrap@fh, nl=\the\swarmwrap@nl}%
    % v3.41: Save figure vertical extent for overlap prevention.
    \global\swarmwrap@fig@ystart=\pagetotal
    \global\swarmwrap@fig@height=\swarmwrap@fh
  \else
    % NORMAL or SQUEEZE-FIT: set up state and place figure immediately.
    % v3.41: Save original tw before clamping so we can detect changes.
    \swarmwrap@saved@origtw=\swarmwrap@tw\relax
    \global\swarmwrap@remaining@nl=\swarmwrap@nl
    \emergencystretch=\fontdimen6\font\relax
    \directlua{
      local stack = swarmwrap_fig_stack
      local tw_val = tex.dimen["swarmwrap@tw@lua"]
      local nl_val = tex.count["swarmwrap@nl"]
      table.insert(stack, {
        tw = tw_val,
        nl = nl_val,
        remaining_nl = nl_val
      })
      local min_tw = tw_val
      local si = 1
      while stack[si] do
        if stack[si].tw > 0 and stack[si].tw < min_tw then
          min_tw = stack[si].tw
        end
        si = si + 1
      end
      if min_tw > 0 and min_tw < tw_val then
        tex.dimen["swarmwrap@tw@lua"] = min_tw
        tex.dimen["swarmwrap@tw"] = min_tw
      end
    }%
    % v3.41: Rebuild parshape with clamped tw if it changed.
    \ifdim\swarmwrap@tw@lua<\swarmwrap@saved@origtw\relax
      \swarmwrap@tw=\swarmwrap@tw@lua\relax
      \xdef\swarmwrap@tw@val{\the\swarmwrap@tw}%
      \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@nl+1\relax\space}%
      \swarmwrap@loop@cnt=\swarmwrap@nl
      \loop
        \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
        \advance\swarmwrap@loop@cnt by -1
      \ifnum\swarmwrap@loop@cnt>0 \repeat
      \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\linewidth\space}%
    \fi
    \swarmwrap@ext@skiptrue
    \ifnum\@listdepth=0\relax
      \everypar=\expandafter{\swarmwrap@apply@ext@pshape}%
    \fi
    \noindent
    \parshape \swarmwrap@pshape\relax
    \ifswarmwrap@squeezed
      \smash{\rlap{\hskip\swarmwrap@tw@val\hskip\swarmwrap@gap\raise\dimexpr\ht\strutbox-\ht\swarmwrap@scaledbox\relax\hbox{\copy\swarmwrap@scaledbox}}}%
      \wlog{swarmwrap next: SQUEEZE --- fh=\the\swarmwrap@fh, fw=\the\swarmwrap@fw, nl=\the\swarmwrap@nl}%
    \else
      \smash{\rlap{\hskip\swarmwrap@tw@val\hskip\swarmwrap@gap\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}}}%
      \wlog{swarmwrap next: NORMAL --- tw=\the\swarmwrap@tw, fh=\the\swarmwrap@fh, nl=\the\swarmwrap@nl, remaining=\the\dimen0}%
    \fi
    % v3.41: Save figure vertical extent for overlap prevention.
    \global\swarmwrap@fig@ystart=\pagetotal
    \global\swarmwrap@fig@height=\swarmwrap@fh
  \fi
}%
\else
\newcommand{\swarmwrapnext}{%
  \PackageError{swarmwrap}{LuaLaTeX required for wrapping. Text wrapping is not supported on pdfLaTeX/XeLaTeX. Either compile with lualatex, or remove swarmwrap.}{}%
}%
\fi

\endinput
