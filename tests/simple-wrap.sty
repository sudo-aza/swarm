% simple-wrap.sty — Minimal right-side float wrapper (based on zwrap v0.2)
% Works with pdfLaTeX, XeLaTeX, and LuaLaTeX
%
% HOW IT WORKS:
%   1. \begin{simplewrap}...\end{simplewrap} captures your figure
%   2. \end{simplewrap} measures it, computes parshape, then pushes
%      placement + parshape setup outside the group via \aftergroup
%      (so parshape survives the environment's \endgroup)
%   3. Text immediately after \end{simplewrap} wraps around the figure
%   4. Wrapping stops when text passes the figure or crosses a page
%
% QUICK START:
%   \usepackage{simple-wrap}
%   \begin{simplewrap}
%     \includegraphics[width=4cm]{photo}
%     \captionof{figure}{My photo}
%   \end{simplewrap}
%   Lorem ipsum — this text wraps around the figure automatically.
%
% ONE environment. No extra commands.

\ProvidesPackage{simple-wrap}[2026/05/31 v0.7]
\RequirePackage{graphicx}

% ─── Internal state ──────────────────────────────────────────────

\newsavebox{\swrap@box}
\newdimen\swrap@fw         % figure width
\newdimen\swrap@fh         % figure height (ht + dp)
\newdimen\swrap@tw         % text width beside figure
\newcount\swrap@nl         % narrow lines for parshape
\newcount\swrap@tmp        % loop counter (reusable, allocated once)
\newcount\swrap@figpage    % page number where figure was placed
\newif\ifswrap@active
\newif\ifswrap@neednewpage

\let\swrap@origpar\par

% ─── Environment ─────────────────────────────────────────────────
% \parshape is LOCAL to the current TeX group. \newenvironment wraps
% begin/end code in \begingroup/\endgroup, which kills local \parshape.
% SOLUTION: Build parshape string via \xdef (global macro), push the
% entire setup (placement + parshape + activation) outside the group
% via \aftergroup\swrap@setup. The \swrap@setup macro fires after
% \endgroup, in the document body scope where \parshape persists.

\newenvironment{simplewrap}{%
  \begin{lrbox}{\swrap@box}%
}{%
  \end{lrbox}%
  \global\setbox\swrap@box=\box\swrap@box
  % ── Measure the captured figure ─────────────────────────────────
  \swrap@fw=\wd\swrap@box
  % FIX: Cap figure width at linewidth to prevent overflow.
  \ifdim\swrap@fw>\linewidth\relax
    \swrap@fw=\linewidth\relax
  \fi
  \swrap@fh=\ht\swrap@box
  \advance\swrap@fh by \dp\swrap@box
  % FIX: Add 1*baselineskip padding to prevent text-figure overlap.
  % Without padding, the last narrow line's baseline sits at the
  % figure bottom, allowing descenders to overlap the figure.
  \advance\swrap@fh by 1\baselineskip
  %
  % ── Clean up any previous wrapping ──────────────────────────────
  \swrap@activefalse
  \global\let\par\swrap@origpar
  \parshape=0\relax
  \swrap@neednewpagefalse
  %
  % ── Compute text width (page width minus figure minus gap) ───────
  \swrap@tw=\linewidth
  \advance\swrap@tw by -\swrap@fw
  \advance\swrap@tw by -10pt   % gap between text and figure
  \ifdim\swrap@tw<0pt\relax
    \swrap@tw=0pt\relax
  \fi
  \xdef\swrap@tw@val{\the\swrap@tw}%
  %
  % ── How many narrow lines fit beside the figure? ────────────────
  \swrap@nl=0
  \dimen0=\swrap@fh
  \loop
    \advance\dimen0 by -\baselineskip
    \advance\swrap@nl by 1
  \ifdim\dimen0>0pt \repeat
  \global\swrap@nl=\swrap@nl
  %
  % ── Newpage detection ──────────────────────────────────────────
  \dimen0=\pagegoal
  \advance\dimen0 by -\pagetotal
  \dimen1=\swrap@nl\baselineskip
  \advance\dimen1 by 2\baselineskip
  \ifdim\dimen0<\dimen1
    \global\swrap@neednewpagetrue
  \fi
  %
  % ── Record figure page ────────────────────────────────────────
  \global\swrap@figpage=\c@page
  %
  % ── Build parshape string (global via \xdef) ──────────────────
  % Format: N indent1 width1 indent2 width2 ... indentN widthN
  % N = nl+1 (nl narrow entries + 1 trailing full-width entry)
  \xdef\swrap@pshape{\the\numexpr\swrap@nl+1\relax\space}%
  \swrap@tmp=0
  \loop
    \xdef\swrap@pshape{\swrap@pshape 0pt \the\swrap@tw\space}%
    \advance\swrap@tmp by 1
  \ifnum\swrap@tmp<\swrap@nl \repeat
  % Trailing full-width entry: resets text to \linewidth after figure
  \xdef\swrap@pshape{\swrap@pshape 0pt \linewidth\space}%
  \typeout{simplewrap v0.7: fw=\the\swrap@fw, fh=\the\swrap@fh, tw=\the\swrap@tw, nl=\the\swrap@nl}%
  %
  % ── Push setup outside the group via \aftergroup ────────────
  \aftergroup\swrap@setup
}

% ─── Setup: runs after \endgroup, before user's text ──────────────
% CRITICAL: \parshape must be set BEFORE \noindent.
% TeX reads \parshape when it starts a new paragraph (at \noindent
% or when text begins in vertical mode). Setting it mid-paragraph
% has NO effect on the current paragraph.
%
% The \noindent starts the paragraph; \smash{\rlap{...}} places the
% figure with zero width so it doesn't affect line-breaking. The
% user's text continues the same paragraph and is narrowed by parshape.

\def\swrap@setup{%
  \ifswrap@neednewpage
    \newpage
    \global\swrap@neednewpagefalse
    \global\swrap@figpage=\c@page
  \fi
  % Set parshape BEFORE starting the paragraph.
  \parshape\swrap@pshape\relax
  % Start paragraph and place figure.
  \noindent
  \smash{\rlap{%
    \hskip\swrap@tw@val
    \hskip10pt
    \raise\dimexpr\ht\strutbox-\ht\swrap@box\relax
    \hbox{\copy\swrap@box}%
  }}%
  % Activate wrapping for multi-paragraph extension.
  \swrap@activetrue
  \emergencystretch=\fontdimen6\font\relax
  \let\par\swrap@patchedpar
  \typeout{swrap@setup: placed figure, parshape applied, wrapping active}%
}

% ─── Patched \par — stops wrapping when done ─────────────────────
\def\swrap@patchedpar{%
  \ifswrap@active
    \ifnum\c@page>\swrap@figpage\relax
      \swrap@activefalse
      \let\par\swrap@origpar
      \parshape=0\relax
    \else
      \global\advance\swrap@nl by -1
      \ifnum\swrap@nl<1\relax
        \swrap@activefalse
        \let\par\swrap@origpar
        \parshape=0\relax
      \fi
    \fi
  \fi
  \swrap@origpar
}

\endinput
