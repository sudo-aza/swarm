\ProvidesFile{tuerewhon-math.fd}
        [2026-03-24 v0.8 NFSS font definitions for Erewhon Math]
\DeclareFontFamily{TU}{erewhon-math}{}
\DeclareFontShape{TU}{erewhon-math}{m}{n}%
  {<-> \UnicodeFontFile{Erewhon-Math}{mode=base;script=math;language=dflt;}}{}
\DeclareFontShape{TU}{erewhon-math}{b}{n}%
  {<-> \UnicodeFontFile{Erewhon-Math-Bold}{mode=base;script=math;language=dflt;}}{}

\DeclareMathScriptfontMapping{TU}{erewhon-math}{TU}{erewhon-math-sf}{TU}{erewhon-math-ssf}
\endinput
