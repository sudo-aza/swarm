\ProvidesFile{tuncmm-ssf.fd}
        [2026-03-24 v0.8 NFSS font definitions for New Computer Modern Math Subscript]
\DeclareFontFamily{TU}{ncmm-ssf}{}
\DeclareFontShape{TU}{ncmm-ssf}{m}{n}%
  {<-> \UnicodeFontFile{NewCMMath-Book}{mode=base;script=math;language=dflt;ssty=2;}}{}
\DeclareFontShape{TU}{ncmm-ssf}{b}{n}%
  {<-> \UnicodeFontFile{NewCMMath-Bold}{mode=base;script=math;language=dflt;ssty=2;}}{}

\endinput
