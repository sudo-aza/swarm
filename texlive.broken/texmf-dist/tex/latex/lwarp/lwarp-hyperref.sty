\newcommand*{\LWR@hyperrefbb}[3]{%
    \ifnumcomp{\value{LWR@linkdepth}}{>}{0}%
        {%
            \endgroup%
            \let\LWR@tempnext\@gobble%
        }%
        {%
            \addtocounter{LWR@linkdepth}{1}%
            \LWR@htmltag{%
                a href=\textquotedbl%
                    \detokenize\expandafter{#1}\LWR@hashmark%
                    \detokenize\expandafter{#2}.\detokenize\expandafter{#3}%
                \textquotedbl%
                \LWR@addlinktitle%
            }%
            \endgroup%
            \let\LWR@tempnext\LWR@hyperreffinish%
        }%
    \LWR@tempnext%
}

