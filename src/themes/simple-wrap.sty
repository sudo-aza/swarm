% simple-wrap.sty — Simplistic right-side float wrapper (v1.0)
%
% Minimal text wrapping using \parshape. No Lua, no callbacks,
% no multi-paragraph extension, no ghost-narrowing prevention.
% Just the basics: capture a box, narrow text beside it, done.
%
% Usage:
%   \usepackage{simple-wrap}
%
%   \begin{simplewrap}%
%     \begin{minipage}[t]{3cm}
%       \centering
%       \rule{\linewidth}{4cm}%
%       \captionof{figure}{Caption.}
%     \end{minipage}%
%   \end{simplewrap}%
%   \simplewrapnext
%   Text wraps around the figure on the right side.
%
% Zero arguments. Width and height are auto-detected from the
% rendered content box. The user controls the content width
% explicitly (e.g., \includegraphics[width=3cm] or
% \begin{minipage}[t]{3cm}).
%
% BUG PREVENTION (v1.0):
%   1. Figure width is capped at \linewidth to prevent figures
%      from extending beyond the page boundary.
%   2. Parshape line count uses box.height + box.depth +
%      1*baselineskip padding to prevent text from extending
%      into the figure zone.
%   3. A trailing full-width parshape entry resets text to full
%      linewidth after the figure zone ends.
%
% Works with pdfLaTeX, XeLaTeX, and LuaLaTeX.

\ProvidesPackage{simple-wrap}[2026/05/31 v1.0 Simplistic right-side float wrapper]

\RequirePackage{graphicx}

\newsavebox{\simplewrap@box}
\newdimen\simplewrap@fw       % figure width
\newdimen\simplewrap@fh       % figure height (with padding for parshape)
\newdimen\simplewrap@tw       % text width (for parshape)
\newcount\simplewrap@nl        % number of narrow parshape lines
\newcount\simplewrap@loop@cnt   % loop counter

% Global macros to persist across the environment group boundary.
\newcommand{\simplewrap@fw@val}{0pt}
\newcommand{\simplewrap@fh@val}{0pt}
\newcommand{\simplewrap@tw@val}{0pt}
\newcommand{\simplewrap@pshape@val}{} % pre-built parshape string

% ── Environment: capture content into a savebox ────────────────────
\newenvironment{simplewrap}{%
  \begin{lrbox}{\simplewrap@box}%
}{%
  \end{lrbox}%
  \global\setbox\simplewrap@box=\box\simplewrap@box
  % BUG FIX #1: Cap figure width at \linewidth to prevent
  % figures from extending beyond the page boundary.
  \simplewrap@fw=\wd\simplewrap@box
  \ifdim\simplewrap@fw>\linewidth\relax
    \simplewrap@fw=\linewidth\relax
    \PackageWarning{simple-wrap}{Figure width capped at \string\linewidth}%
  \fi
  \xdef\simplewrap@fw@val{\the\simplewrap@fw}%
  % BUG FIX #2: Use box.height + box.depth + 1*baselineskip
  % for parshape line count. The extra baselineskip provides
  % clearance so text never extends into the figure zone.
  \simplewrap@fh=\ht\simplewrap@box
  \advance\simplewrap@fh by \dp\simplewrap@box
  \advance\simplewrap@fh by 1\baselineskip
  \xdef\simplewrap@fh@val{\the\simplewrap@fh}%
  % Compute text width: full linewidth minus figure minus gap.
  \simplewrap@tw=\linewidth
  \advance\simplewrap@tw by -\simplewrap@fw
  \advance\simplewrap@tw by -10pt  % 10pt gap between text and figure
  % BUG FIX #1 (continued): If text width would be negative,
  % the figure is too wide. Clamp it.
  \ifdim\simplewrap@tw<0pt\relax
    \simplewrap@tw=0pt\relax
  \fi
  \xdef\simplewrap@tw@val{\the\simplewrap@tw}%
  % Compute number of narrow lines from figure height.
  \simplewrap@nl=0
  \dimen0=\simplewrap@fh
  \loop
    \advance\simplewrap@nl by 1
    \advance\dimen0 by -\baselineskip
  \ifdim\dimen0>0pt \repeat
  % Build parshape string: nl narrow entries + 1 trailing full-width.
  % BUG FIX #3: Trailing full-width entry ensures text resets to
  % full linewidth after the figure zone. Without this, TeX repeats
  % the last narrow entry for ALL subsequent lines permanently.
  \xdef\simplewrap@pshape@val{\the\numexpr\simplewrap@nl+1\relax\space}%
  \simplewrap@loop@cnt=\simplewrap@nl
  \loop
    \xdef\simplewrap@pshape@val{\simplewrap@pshape@val 0pt \the\simplewrap@tw\space}%
    \advance\simplewrap@loop@cnt by -1
  \ifnum\simplewrap@loop@cnt>0 \repeat
  % Trailing full-width entry
  \xdef\simplewrap@pshape@val{\simplewrap@pshape@val 0pt \linewidth\space}%
  \typeout{simple-wrap v1.0: fw=\the\simplewrap@fw, fh=\the\simplewrap@fh, tw=\the\simplewrap@tw, nl=\the\simplewrap@nl}%
}

% ── \simplewrapnext: apply parshape and place figure ──────────────────
\newcommand{\simplewrapnext}{%
  % Restore values from the environment (global macros survive the group).
  \simplewrap@fw=\simplewrap@fw@val\relax
  \simplewrap@tw=\simplewrap@tw@val\relax
  % Check remaining space on current page.
  \dimen0=\pagegoal
  \advance\dimen0 by -\pagetotal
  \simplewrap@fh=\simplewrap@fh@val\relax
  \ifdim\dimen0<\simplewrap@fh
    % Figure doesn't fit on current page — eject to next page.
    % Text on the current page runs at full width (no wrapping).
    % On the next page, the figure wraps at the top-right.
    \parshape 1 0pt \linewidth\relax
    \newpage
  \fi
  % Apply parshape for wrapped text.
  \parshape \simplewrap@pshape@val\relax
  % Place figure at the right margin using smash/rlap overlay.
  % The figure is positioned to the right of the narrowed text zone.
  \noindent
  \smash{\rlap{\hskip\simplewrap@tw@val\hskip10pt\raise\dimexpr\ht\strutbox-\ht\simplewrap@box\relax\hbox{\copy\simplewrap@box}}}%
  \typeout{simple-wrap next: placed figure, tw=\the\simplewrap@tw, nl from pshape applied}%
}

\endinput
