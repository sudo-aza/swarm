% simple-wrap.sty — Minimal right-side float wrapper
% Works with pdfLaTeX, XeLaTeX, and LuaLaTeX
%
% HOW IT WORKS:
%   1. \begin{simplewrap}...\end{simplewrap} captures your figure
%   2. \end{simplewrap} places it top-right and sets up parshape
%   3. Text immediately after \end{simplewrap} wraps around the figure
%   4. Wrapping stops when text passes the figure or crosses a page
%
% QUICK START:
%   \usepackage{simple-wrap}
%   \begin{simplewrap}
%     \includegraphics[width=4cm]{photo}
%     \captionof{figure}{My photo}
%   \end{simplewrap}
%   Lorem ipsum — this text wraps around the figure automatically.
%
% ONE environment. No extra commands.

\ProvidesPackage{simple-wrap}[2026/05/31 v0.3]
\RequirePackage{graphicx}

% ─── Internal state ──────────────────────────────────────────────

\newbox\swrap@box          % holds the captured figure
\newdimen\swrap@fw         % figure width
\newdimen\swrap@fh         % figure height (ht + dp)
\newdimen\swrap@tw         % text width beside figure
\newcount\swrap@nl         % narrow lines remaining in current parshape
\newcount\swrap@figpage    % page number where figure was placed
\newif\ifswrap@active      % is wrapping currently active?

\let\swrap@origpar\par    % save original \par

% ─── \begin{simplewrap}...\end{simplewrap} ──────────────────────
% Begin: start capturing figure content into a box.
% End: measure it, check page space, place figure, set parshape.

\newenvironment{simplewrap}{%
  \global\setbox\swrap@box=\vbox\bgroup
  \hsize=4cm\relax        % default figure width, user can override
  \centering
}{%
  \egroup
  % ── Measure the captured figure ─────────────────────────────────
  \swrap@fw=\wd\swrap@box
  % BUG FIX: Cap figure width at linewidth so it never extends past
  % the right page boundary.
  \ifdim\swrap@fw>\linewidth\relax
    \swrap@fw=\linewidth\relax
  \fi
  \swrap@fh=\ht\swrap@box
  \advance\swrap@fh by \dp\swrap@box
  % BUG FIX: Add 1*baselineskip padding to figure height for parshape
  % line count. Without this, the last narrow line's baseline sits
  % right at the figure bottom, allowing text to visually extend
  % into the figure zone. The extra baselineskip gives clearance.
  \advance\swrap@fh by 1\baselineskip
  %
  % ── Clean up any previous wrapping ──────────────────────────────
  \swrap@activefalse
  \let\par\swrap@origpar
  \parshape=0\relax
  %
  % ── Compute text width (page width minus figure minus gap) ───────
  \swrap@tw=\linewidth
  \advance\swrap@tw by -\swrap@fw
  \advance\swrap@tw by -10pt   % gap between text and figure
  % Clamp: if figure is too wide, text width goes to zero
  \ifdim\swrap@tw<0pt\relax
    \swrap@tw=0pt\relax
  \fi
  %
  % ── How many narrow lines fit beside the figure? ────────────────
  \swrap@nl=0
  \dimen0=\swrap@fh
  \loop
    \advance\dimen0 by -\baselineskip
    \advance\swrap@nl by 1
  \ifdim\dimen0>0pt \repeat
  %
  % ── Newpage detection: does it fit on current page? ──────────────
  \dimen0=\pagegoal
  \advance\dimen0 by -\pagetotal
  \dimen1=\swrap@nl\baselineskip
  \advance\dimen1 by 2\baselineskip  % 2-line safety margin
  %
  \ifdim\dimen0<\dimen1
    % ── NOT ENOUGH SPACE — eject to new page ─────────────────────
    \newpage
  \fi
  %
  % ── Record figure page and place it ────────────────────────────
  \global\swrap@figpage=\c@page
  \noindent
  \smash{%
    \rlap{%
      \hskip\swrap@tw
      \hskip10pt
      \raise\dimexpr\ht\strutbox-\ht\swrap@box\relax
      \hbox{\copy\swrap@box}%
    }%
  }%
  %
  % ── Build parshape: nl narrow lines + 1 trailing full-width ──────
  \xdef\swrap@pshape{\the\numexpr\swrap@nl+1\relax\space}%
  \newcount\swrap@tmp
  \swrap@tmp=0
  \loop
    \xdef\swrap@pshape{\swrap@pshape 0pt \the\swrap@tw\space}%
    \advance\swrap@tmp by 1
  \ifnum\swrap@tmp<\swrap@nl \repeat
  \xdef\swrap@pshape{\swrap@pshape 0pt \linewidth\space}%
  \parshape\swrap@pshape\relax
  %
  % ── Activate wrapping ─────────────────────────────────────────
  \swrap@activetrue
  \emergencystretch=\fontdimen6\font\relax
  \let\par\swrap@patchedpar
}

% ─── Patched \par — stops wrapping when done ─────────────────────
% After each paragraph break, check if we should deactivate:
%   a) crossed to a new page → figure is behind us
%   b) ran out of narrow lines → passed the figure

\def\swrap@patchedpar{%
  \ifswrap@active
    \ifnum\c@page>\swrap@figpage\relax
      \swrap@activefalse
      \let\par\swrap@origpar
      \parshape=0\relax
    \else
      \global\advance\swrap@nl by -1
      \ifnum\swrap@nl<1\relax
        \swrap@activefalse
        \let\par\swrap@origpar
        \parshape=0\relax
      \fi
    \fi
  \fi
  \swrap@origpar
}

\endinput
