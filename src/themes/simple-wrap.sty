% simple-wrap.sty — Minimal right-side float wrapper
% Works with pdfLaTeX, XeLaTeX, and LuaLaTeX
%
% HOW IT WORKS:
%   1. \begin{simplewrap}...\end{simplewrap} captures your figure
%   2. \end{simplewrap} places it top-right and sets up parshape
%   3. Text immediately after \end{simplewrap} wraps around the figure
%   4. Wrapping stops when text passes the figure or crosses a page
%
% QUICK START:
%   \usepackage{simple-wrap}
%   \begin{simplewrap}
%     \includegraphics[width=4cm]{photo}
%     \captionof{figure}{My photo}
%   \end{simplewrap}
%   Lorem ipsum — this text wraps around the figure automatically.
%
% ONE environment. No extra commands.

\ProvidesPackage{simple-wrap}[2026/05/31 v0.6]
\RequirePackage{graphicx}

% ─── Internal state ──────────────────────────────────────────────

\newsavebox{\swrap@box}
\newdimen\swrap@fw         % figure width
\newdimen\swrap@fh         % figure height (ht + dp)
\newdimen\swrap@tw         % text width beside figure
\newcount\swrap@nl         % narrow lines for parshape
\newcount\swrap@figpage    % page number where figure was placed
\newif\ifswrap@active
\newif\ifswrap@neednewpage

\let\swrap@origpar\par

% ─── Environment ─────────────────────────────────────────────────
% ARCHITECTURE (v0.6):
% \parshape is LOCAL to the current TeX group. \newenvironment's
% implicit \begingroup/\endgroup kills it. Previous attempts with
% \aftergroup partially worked but had ~7-35pt discrepancy between
% the parshape spec and actual text width.
%
% ROOT CAUSE of discrepancy: \noindent inside \swrap@setup starts
% a paragraph in horizontal mode. The paragraph uses parshape, but
% the \smash{\rlap{...}} box (zero width) occupies the line-start.
% When TeX breaks lines, it counts the \noindent line as line 1 of
% the parshape, consuming one narrow entry. The user's text starts
% on line 1 (same line, after the zero-width box) and overflows the
% parshape width because TeX already allocated space for the \noindent.
%
% FIX (v0.6): Don't start a paragraph in \swrap@setup. Instead:
% 1. Place the figure in vertical mode using \rlap overlay at
%    the top of the page, BEFORE any paragraph starts.
% 2. Set parshape for the NEXT paragraph.
% 3. Let the user's text naturally start the paragraph, which
%    picks up the parshape.
% 4. Use \leavevmode\vadjust to place the figure box at the
%    current vertical position without starting horizontal mode.

\newenvironment{simplewrap}{%
  \begin{lrbox}{\swrap@box}%
}{%
  \end{lrbox}%
  \global\setbox\swrap@box=\box\swrap@box
  % ── Measure the captured figure ─────────────────────────────────
  \swrap@fw=\wd\swrap@box
  % Cap figure width at linewidth to prevent overflow.
  \ifdim\swrap@fw>\linewidth\relax
    \swrap@fw=\linewidth\relax
  \fi
  \swrap@fh=\ht\swrap@box
  \advance\swrap@fh by \dp\swrap@box
  \advance\swrap@fh by 1\baselineskip
  %
  % ── Clean up any previous wrapping ──────────────────────────────
  \swrap@activefalse
  \global\let\par\swrap@origpar
  \parshape=0\relax
  \swrap@neednewpagefalse
  %
  % ── Compute text width (page width minus figure minus gap) ───────
  \swrap@tw=\linewidth
  \advance\swrap@tw by -\swrap@fw
  \advance\swrap@tw by -20pt   % gap between text and figure
  \ifdim\swrap@tw<0pt\relax
    \swrap@tw=0pt\relax
  \fi
  \xdef\swrap@tw@val{\the\swrap@tw}%  % survive group boundary
  %
  % ── How many narrow lines fit beside the figure? ────────────────
  \swrap@nl=0
  \dimen0=\swrap@fh
  \loop
    \advance\dimen0 by -\baselineskip
    \advance\swrap@nl by 1
  \ifdim\dimen0>0pt \repeat
  %
  % ── Newpage detection ──────────────────────────────────────────
  \dimen0=\pagegoal
  \advance\dimen0 by -\pagetotal
  \dimen1=\swrap@nl\baselineskip
  \advance\dimen1 by 2\baselineskip
  \ifdim\dimen0<\dimen1
    \global\swrap@neednewpagetrue
  \fi
  %
  % ── Record figure page ────────────────────────────────────────
  \global\swrap@figpage=\c@page
  %
  % ── Build parshape string (global via \xdef) ──────────────────
  \xdef\swrap@pshape{\the\numexpr\swrap@nl+1\relax\space}%
  \newcount\swrap@tmp
  \swrap@tmp=0
  \loop
    \xdef\swrap@pshape{\swrap@pshape 0pt \the\swrap@tw\space}%
    \advance\swrap@tmp by 1
  \ifnum\swrap@tmp<\swrap@nl \repeat
  \xdef\swrap@pshape{\swrap@pshape 0pt \linewidth\space}%
  %
  % ── Push setup outside the group via \aftergroup ────────────
  \aftergroup\swrap@setup
}

% ─── Setup: figure placement + parshape + activation ──────────────
% Runs in document body scope (after \endgroup).
% KEY CHANGE (v0.6): Place figure using \vadjust, NOT \noindent.
% \vadjust inserts vertical material at the current line's top
% without starting a paragraph. The figure appears at the right
% margin, and the user's text starts a NEW paragraph that picks
% up the parshape.
\def\swrap@setup{%
  \ifswrap@neednewpage
    \newpage
    \global\swrap@neednewpagefalse
    \global\swrap@figpage=\c@page
  \fi
  % Set parshape BEFORE any paragraph starts.
  \parshape\swrap@pshape\relax
  % Activate wrapping.
  \swrap@activetrue
  \emergencystretch=\fontdimen6\font\relax
  \let\par\swrap@patchedpar
  % Place figure at the right margin.
  % Use \smash{\llap{...}} which works in vertical mode:
  % it produces a zero-height, zero-width box that overlays
  % the figure at the right margin position.
  \smash{%
    \llap{%
      \vbox to 0pt{%
        \offinterlineskip
        \rlap{%
          \hskip\swrap@tw@val
          \hskip20pt
          \raise\dimexpr\ht\strutbox-\ht\swrap@box\relax
          \hbox{\copy\swrap@box}%
        }%
        \vss
      }%
    }%
  }%
}

% ─── Patched \par — stops wrapping when done ─────────────────────
\def\swrap@patchedpar{%
  \ifswrap@active
    \ifnum\c@page>\swrap@figpage\relax
      \swrap@activefalse
      \let\par\swrap@origpar
      \parshape=0\relax
    \else
      \global\advance\swrap@nl by -1
      \ifnum\swrap@nl<1\relax
        \swrap@activefalse
        \let\par\swrap@origpar
        \parshape=0\relax
      \fi
    \fi
  \fi
  \swrap@origpar
}

\endinput
