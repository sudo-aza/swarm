% =============================================================================
% swarmbeauty.sty — The "Beautiful" Theme for the LaTeX Helper Swarm
%
% A comprehensive, modern document theme built on KOMA-Script with:
%   - Elegant color palette with customizable accent colors
%   - Beautiful title page with subtle background
%   - Styled section/chapter headings with rule decorations
%   - Professional tables with booktabs + tabularray
%   - Syntax-highlighted code blocks via minted + tcolorbox
%   - Polished headers/footers with page numbers
%   - Custom block environments (note, tip, warning, example)
%   - Optimized typography with fontspec + microtype
%   - Clean bibliography support via biblatex
%
% Usage:
%   \documentclass[11pt, a4paper]{scrartcl}
%   \usepackage{swarmbeauty}
%
% Requires: LuaLaTeX or XeLaTeX (--shell-escape for minted)
% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{swarmbeauty}[2026/05/14 v0.2.0 LaTeX Helper Swarm — Beautiful Theme]

% ── Engine check ─────────────────────────────────────────────────────────────
\RequirePackage{iftex}
\ifPDFTeX
  \PackageError{swarmbeauty}{%
    This theme requires LuaLaTeX or XeLaTeX.\MessageBreak
    Compile with: lualatex --shell-escape myfile.tex}{}
  \stop
\fi

% ── Core packages ────────────────────────────────────────────────────────────
\RequirePackage{tikz}
\usetikzlibrary{calc, positioning, arrows.meta, shapes.geometric}
\RequirePackage{fontspec}
\RequirePackage{microtype}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{calc}
\RequirePackage{etoolbox}
\RequirePackage{csquotes}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{mathtools}
\RequirePackage{booktabs}
\RequirePackage{tabularray}
\RequirePackage{caption}
\RequirePackage{subcaption}
\RequirePackage{float}
\RequirePackage{placeins}
\RequirePackage{enumitem}
\RequirePackage{hyperref}
\RequirePackage{fancyhdr}
\RequirePackage{tcolorbox}
\tcbuselibrary{minted, skins, breakable, theorems}

% ── Color Palette ────────────────────────────────────────────────────────────

\definecolor{sbPrimary}{HTML}{2C3E50}
\definecolor{sbSecondary}{HTML}{3498DB}
\definecolor{sbAccent}{HTML}{E74C3C}
\definecolor{sbSuccess}{HTML}{27AE60}
\definecolor{sbWarning}{HTML}{F39C12}
\definecolor{sbLight}{HTML}{ECF0F1}
\definecolor{sbMedium}{HTML}{BDC3C7}
\definecolor{sbDark}{HTML}{2C3E50}
\definecolor{sbCodeBg}{HTML}{F8F9FA}
\definecolor{sbText}{HTML}{2C3E50}

% ── Typography ───────────────────────────────────────────────────────────────

\setmainfont{Latin Modern Roman}[
  AutoFakeBold       = 2,
  AutoFakeSlant      = 0.2,
  Ligatures          = TeX,
]
\setsansfont{Latin Modern Sans}[
  AutoFakeBold       = 2,
  AutoFakeSlant      = 0.2,
  Ligatures          = TeX,
]
\setmonofont{Latin Modern Mono}[
  Scale              = MatchLowercase,
  AutoFakeBold       = 2,
  AutoFakeSlant      = 0.2,
  Ligatures          = TeX,
]

% ── Page Layout ──────────────────────────────────────────────────────────────
% Paper size and margins — use geometry for maximum compatibility
\RequirePackage[margin=2.5cm, a4paper]{geometry}

% Set paragraph skip (since we're not using KOMA typearea)
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5\baselineskip plus 0.1\baselineskip minus 0.1\baselineskip}

% ── Font commands for structure ───────────────────────────────────────────────

\newcommand{\sftitle}{\color{sbPrimary}\fontsize{28}{34}\selectfont\bfseries\sffamily}
\newcommand{\sfsubtitle}{\color{sbSecondary}\fontsize{16}{20}\selectfont\mdseries\sffamily}
\newcommand{\sfauthor}{\color{sbDark}\fontsize{12}{14}\selectfont}
\newcommand{\sfdate}{\color{sbMedium}\fontsize{10}{12}\selectfont}

% KOMA provides \inserttitle etc. but we provide LaTeX-standard fallbacks
\providecommand{\inserttitle}{\@title}
\providecommand{\insertsubtitle}{\@subtitle}
\providecommand{\insertauthor}{\@author}
\providecommand{\insertdate}{\@date}

% ── Section Heading Styling ──────────────────────────────────────────────────

% Use titlesec for reliable section formatting across all LaTeX versions
\RequirePackage[compact]{titlesec}

\titleformat{\section}
  {\large\sffamily\bfseries\color{sbPrimary}}
  {\thesection}{0.5em}{}
  [\vspace{-0.5em}{\color{sbSecondary}\rule{\textwidth}{0.8pt}}\vspace{0.3em}]

\titleformat{\subsection}
  {\normalsize\sffamily\bfseries\color{sbPrimary}}
  {\thesubsection}{0.5em}{}
  [\vspace{-0.5em}{\color{sbMedium}\rule{0.4\textwidth}{0.4pt}}\vspace{0.2em}]

\titleformat{\subsubsection}
  {\small\sffamily\itshape\color{sbDark}}
  {\thesubsubsection}{0.5em}{}

\titlespacing*{\section}{0pt}{2.5ex plus 1ex minus 0.5ex}{1.5ex}
\titlespacing*{\subsection}{0pt}{1.8ex plus 0.8ex}{1.0ex}
\titlespacing*{\subsubsection}{0pt}{1.2ex plus 0.5ex}{0.8ex}

% ── Title Page ───────────────────────────────────────────────────────────────

\newcommand{\swarmtitlepage}{%
  \begin{titlepage}
    % Background accent bar at top
    \begin{tikzpicture}[remember picture, overlay]
      \fill[sbPrimary]
        (current page.north west) rectangle
        ([yshift=-3cm]current page.north east);
      \fill[sbSecondary]
        ([yshift=-3cm]current page.north west) rectangle
        ([yshift=-3.15cm]current page.north east);
    \end{tikzpicture}

    \vspace*{1.5cm}
    \begin{center}
      {\sftitle\inserttitle\par}
      \vspace{0.5em}
      {\sfsubtitle\insertsubtitle\par}
    \end{center}

    \vfill

    \begin{center}
      \begin{tcolorbox}[
        colback      = sbLight,
        colframe     = sbSecondary,
        boxrule      = 0pt,
        arc          = 4pt,
        width        = 0.65\textwidth,
        left         = 15pt,
        right        = 15pt,
        top          = 12pt,
        bottom       = 12pt,
        before upper = \centering,
      ]
        {\sfauthor\insertauthor\par}
        \vspace{0.5em}
        {\sfdate\insertdate\par}
      \end{tcolorbox}
    \end{center}

    \vfill
  \end{titlepage}
}

% ── Headers & Footers ────────────────────────────────────────────────────────

\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\color{sbMedium}\footnotesize\sffamily\leftmark}
\fancyhead[R]{\color{sbMedium}\footnotesize\sffamily\@title}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\headrule}{\color{sbMedium}\hrule height 0.4pt}
\fancyfoot[L]{\color{sbMedium}\footnotesize\sffamily\@date}
\fancyfoot[R]{\color{sbSecondary}\sffamily\bfseries\thepage}

% ── Table Styling ────────────────────────────────────────────────────────────

\newcommand{\swarmtoprule}{\specialrule{1.2pt}{0pt}{3pt}\color{sbPrimary}}
\newcommand{\swarmmidrule}{\specialrule{0.6pt}{3pt}{3pt}\color{sbMedium}}
\newcommand{\swarmbottomrule}{\specialrule{1.2pt}{3pt}{0pt}\color{sbPrimary}}

\captionsetup{
  font          = {sf, small},
  labelfont     = {bf, color=sbSecondary},
  labelsep      = quad,
  skip          = 6pt,
  format        = plain,
  indention     = 0pt,
}

% ── Code Listings (minted + tcolorbox) ───────────────────────────────────────

\newtcblisting{codeblock}[2][Python]{%
  listing engine  = minted,
  minted language = #1,
  minted style    = tango,
  minted options  = {
    fontsize     = \small,
    breaklines   = true,
    linenos,
    numbersep    = 8pt,
    autogobble,
  },
  colback         = sbCodeBg,
  colframe        = sbMedium,
  coltitle        = white,
  coltext         = sbDark,
  left            = 10pt,
  right           = 10pt,
  top             = 6pt,
  bottom          = 6pt,
  boxrule         = 0.5pt,
  arc             = 3pt,
  title           = {#2},
  fonttitle       = \sffamily\bfseries\small\color{white},
  titlerule       = 0pt,
  listing only,
  breakable,
  enhanced,
}

% Inline code — use \texttunderscore for literal underscores
\newcommand{\code}[1]{%
  \colorbox{sbCodeBg}{\texttt{\small\textcolor{sbDark}{#1}}}%
}
% For code with underscores, use \code[no-escape]{text_with_underscores}
\newcommand{\codeesc}[1]{%
  \colorbox{sbCodeBg}{\texttt{\small\textcolor{sbDark}{\detokenize{#1}}}}%
}

% ── Block Environments ───────────────────────────────────────────────────────

\newtcolorbox{noteblock}[1][Note]{%
  colback = sbLight, colframe = sbSecondary,
  coltitle = white, fonttitle = \sffamily\bfseries,
  title = {#1}, boxrule = 0pt, arc = 3pt,
  left = 10pt, right = 10pt, top = 6pt, bottom = 6pt,
  enhanced, borderline west = {3pt}{0pt}{sbSecondary},
}

\newtcolorbox{tipblock}[1][Tip]{%
  colback = sbLight, colframe = sbSuccess,
  coltitle = white, fonttitle = \sffamily\bfseries,
  title = {#1}, boxrule = 0pt, arc = 3pt,
  left = 10pt, right = 10pt, top = 6pt, bottom = 6pt,
  enhanced, borderline west = {3pt}{0pt}{sbSuccess},
}

\newtcolorbox{warningblock}[1][Warning]{%
  colback = sbLight, colframe = sbWarning,
  coltitle = white, fonttitle = \sffamily\bfseries,
  title = {#1}, boxrule = 0pt, arc = 3pt,
  left = 10pt, right = 10pt, top = 6pt, bottom = 6pt,
  enhanced, borderline west = {3pt}{0pt}{sbWarning},
}

\newtcolorbox{dangerblock}[1][Important]{%
  colback = sbLight, colframe = sbAccent,
  coltitle = white, fonttitle = \sffamily\bfseries,
  title = {#1}, boxrule = 0pt, arc = 3pt,
  left = 10pt, right = 10pt, top = 6pt, bottom = 6pt,
  enhanced, borderline west = {3pt}{0pt}{sbAccent},
}

\newtcolorbox{exampleblock}[1][Example]{%
  colback = sbCodeBg, colframe = sbMedium,
  coltitle = sbDark, fonttitle = \sffamily\bfseries,
  title = {#1}, boxrule = 0.4pt, arc = 3pt,
  left = 10pt, right = 10pt, top = 6pt, bottom = 6pt,
  enhanced,
}

% ── Hyperlink Styling ────────────────────────────────────────────────────────

\hypersetup{
  colorlinks  = true,
  linkcolor   = sbSecondary,
  urlcolor    = sbSecondary,
  citecolor   = sbSecondary,
  filecolor   = sbSecondary,
}

% ── TOC Styling ──────────────────────────────────────────────────────────────

\RequirePackage{tocloft}
\renewcommand{\cfttoctitlefont}{\Large\sffamily\bfseries\color{sbPrimary}}
\renewcommand{\cftsecfont}{\sffamily\color{sbDark}}
\renewcommand{\cftsubsecfont}{\sffamily\small\color{sbDark}}
\renewcommand{\cftsecleader}{\color{sbMedium}\cftdotfill{1}}
\renewcommand{\cftsubsecleader}{\color{sbMedium}\cftdotfill{1}}

% ── Itemize / Enumerate ─────────────────────────────────────────────────────

\setlist[itemize]{
  label        = \textcolor{sbSecondary}{\textbullet},
  itemsep      = 4pt,
  leftmargin   = 1.2em,
  parsep       = 0pt,
}

\setlist[enumerate]{
  label        = \textcolor{sbSecondary}{\bfseries\arabic*.},
  itemsep      = 4pt,
  leftmargin   = 1.5em,
  parsep       = 0pt,
}

% ── Math Theorem Environments ───────────────────────────────────────────────

\newtcbtheorem[number within=section]{theorem}{Theorem}{%
  colback = sbLight, colframe = sbPrimary,
  fonttitle = \sffamily\bfseries,
  boxrule = 0pt, arc = 2pt,
  left = 8pt, right = 8pt, top = 5pt, bottom = 5pt,
  enhanced, borderline west = {3pt}{0pt}{sbPrimary},
  before skip = 8pt, after skip = 8pt,
}{thm}

\newtcbtheorem[number within=section]{definition}{Definition}{%
  colback = sbLight, colframe = sbSecondary,
  fonttitle = \sffamily\bfseries,
  boxrule = 0pt, arc = 2pt,
  left = 8pt, right = 8pt, top = 5pt, bottom = 5pt,
  enhanced, borderline west = {3pt}{0pt}{sbSecondary},
  before skip = 8pt, after skip = 8pt,
}{def}

\newtcbtheorem[number within=section]{lemma}{Lemma}{%
  colback = sbLight, colframe = sbSuccess,
  fonttitle = \sffamily\bfseries,
  boxrule = 0pt, arc = 2pt,
  left = 8pt, right = 8pt, top = 5pt, bottom = 5pt,
  enhanced, borderline west = {3pt}{0pt}{sbSuccess},
  before skip = 8pt, after skip = 8pt,
}{lem}

% ── Utility Commands ─────────────────────────────────────────────────────────

\newcommand{\hltext}[1]{\textcolor{sbAccent}{\textbf{#1}}}

\newcommand{\emphtext}[1]{%
  \tikz[baseline=(X.base)]
    \node[fill=sbLight, rounded corners=2pt, inner sep=3pt] (X)
    {\textcolor{sbPrimary}{\textbf{#1}}};%
}

\newcommand{\colorrule}{%
  \par\noindent\textcolor{sbSecondary}{\rule{\textwidth}{0.6pt}}\par\vspace{0.5em}%
}

% ── Footnote Styling ────────────────────────────────────────────────────────

\renewcommand{\thefootnote}{\textcolor{sbSecondary}{\arabic{footnote}}}

% ── Bibliography (optional) ──────────────────────────────────────────────────

\AtEndPreamble{%
  \@ifpackageloaded{biblatex}{%
    \setbibfont{small}
  }{}%
}

\endinput
