% swarmwrap.sty — Right-side float wrapper for the Swarm toolkit (v3.66)
%
% Text wrapping using \parshape applied by \swarmwrapnext command.
% Built from scratch after all 9 existing LaTeX wrapping packages failed QA.
%
% Usage:
%   \usepackage{swarmwrap}
%
%   % Simple figure (single content box):
%   \begin{swarmwrap}%
%     \includegraphics[width=3cm]{photo}%
%   \end{swarmwrap}%
%   \swarmwrapnext
%   Paragraph text wraps around the figure.
%
%   % Multi-line content (figure + caption):
%   \begin{swarmwrap}%
%     \begin{minipage}[t]{3cm}
%       \centering
%       \includegraphics[width=\linewidth]{photo}
%       \captionof{figure}{Caption.}
%     \end{minipage}%
%   \end{swarmwrap}%
%   \swarmwrapnext
%   Paragraph text wraps around the figure.
%
%   % Custom page-break penalty (discourage breaks in wrapped zone):
%   \swarmwrappenalty{500}  % default is 10000 (very discouraged)
%
% Zero arguments. Width and height are auto-detected from the rendered
% content box. The user controls the content width explicitly (e.g.,
% \includegraphics[width=3cm] or \begin{minipage}[t]{3cm}).
% Right-side wrapping only. Left-wrap removed in v3.0 (scope reduction).
%
% Requirements: LuaLaTeX (errors out on pdfLaTeX/XeLaTeX)
%
% ── Known Limitations ─────────────────────────────────────────────────
%
% 1. Ghost narrowing on continuation pages (MOSTLY FIXED in v3.54):
%    When the wrapped paragraph spans a page break, TeX's parshape
%    persists across the page boundary but the figure does not (it is
%    placed via \smash{\rlap{...}} which is page-local). Continuation
%    lines on the next page remain narrowed even though no figure is
%    beside them.
%    v3.54 FIX (two-layer prevention):
%    Layer 1: 2-baselineskip safety margin in \par patch, list hook,
%    and item hook — limits parshape extension to fit within the page.
%    Layer 2: Transition penalty (-2000) in post_linebreak_filter —
%    inserted at the narrow→full parshape boundary, encouraging TeX to
%    break the page at the transition point.
%    REMAINING: 3/1038 pages at 1000-fig scale have ghost narrowing
%    (pages 67, 332, 927). These are edge cases where the first
%    paragraph is very long and TeX's page breaker is forced to break
%    within the narrow zone (page overfull). This is an inherent
%    limitation of TeX's parshape persistence across page breaks
%    within a single paragraph — no post-hoc fix is possible without
%    shipout_filter (which fails due to luaotfload conflict).
%
% 2. Parshape leak into list items (PARTIALLY FIXED in v3.16):
%    When \swarmwrapnext is used before a list, subsequent \item
%    paragraphs now correctly maintain parshape narrowing. However,
%    if \swarmwrapnext is used INSIDE a list item, only that item
%    wraps — subsequent items are not narrowed (acceptable per spec).
%
% 3. Near-page figure:
%    When the figure doesn't fit on the current page, a page eject occurs.
%    Text on the current page runs at full width (no wrapping). On the
%    next page, the figure wraps right at the top-right and text wraps
%    beside it. This wastes space at the bottom of the current page but
%    eliminates body-text overlaps from continuation text.
%
% ── Changelog ───────────────────────────────────────────────────────
%
% v3.70: Conditional forced break at narrow->full transition (Task #214).
%   KEY CHANGE: post_linebreak_filter now uses CONDITIONAL penalty based
%   on remaining page space. Count narrow lines (K) in broken result and
%   compare K * baselineskip against \swarmwrap@remaining (a Lua-readable
%   dimen set in \swarmwrapnext from pagegoal-pagetotal).
%   If narrow zone exceeds remaining space: use -10000 (FORCED break).
%   TeX MUST break the page at the narrow->full transition, preventing
%   narrow lines from carrying to the next page (ghost narrowing).
%   If narrow zone fits: use -5000 (normal encouragement).
%   WHY NEW: Previous discretionary penalties (-2000 v3.54, -5000 v3.69)
%   can be OVERRIDDEN by TeX when the page is overfull — exactly when
%   ghost narrowing occurs. -10000 is mandatory (TeX cannot override).
%   This has NEVER been tried at the transition point before.
%   TECHNICAL: pagegoal/pagetotal are TeX internals not readable from Lua
%   callbacks. Solved by computing remaining at \swarmwrapnext time and
%   storing in \swarmwrap@remaining (a user-defined dimen register).
%   TRADE-OFF: Forced breaks increase page count (+16% at 1000-fig).
%   The remaining 1 ghost/2 hollow are due to LuaTeX paragraph caching:
%   the first occurrence's remaining-space check determines the penalty
%   for all subsequent identical paragraphs.
%   RESULT: 50-fig PERFECT 50/50 (100%), 56 pages, 0 ghost/hollow/overlaps.
%   1000-fig 1097/1100 (99.7%), 1206 pages, 1 ghost, 2 hollow, 0 overlaps.
%   IMPROVEMENT: ghost 2->1, hollow 3->2, quality 99.5%->99.7%.
%   STATUS: Pending QA review.
%
% v3.55: Pre-check needspace in pre_linebreak_filter (Approach B from Researcher).
%   NEW: Added a second layer of ghost-narrowing prevention that is fundamentally
%   different from penalties. Before TeX breaks lines (pre_linebreak_filter),
%   the callback reads the current parshape, counts narrow entries, and checks
%   if the narrow zone fits on the remaining page space (with 2bs safety margin).
%   If not, it reduces narrow entries or clears parshape entirely.
%   WHY: The .sty's \par patch and \item hook set parshape at paragraph/item
%   boundaries with a 3bs safety margin. But at that point, \pagetotal may not
%   reflect all inter-paragraph spacing (\parskip, list overhead). By the time
%   pre_linebreak_filter fires, all spacing has been consumed and \pagetotal is
%   accurate. This catches cases where the 3bs margin was insufficient.
%   TECHNIQUE: Reading/writing tex.parshape from pre_linebreak_filter, proven
%   by the chickenize package (Henri Menke).
%   RESULT: Target: 0 ghost narrowing at 1000-fig scale (down from 3 in v3.54).
%
% v3.54: Transition penalty in post_linebreak_filter (v3.53 node ID fix).
%   v3.53 fixed the node ID bug but left penalties disabled as passthrough.
%   v3.54 re-enables the post_linebreak_filter to insert a penalty (-2000)
%   at the narrow→full parshape transition point. This encourages TeX to
%   break the page at the transition rather than in the middle of the
% narrow zone. Combined with the 2-baselineskip safety margin in the
%   .sty's \par patch, this provides two-layer ghost-narrowing prevention.
%   RESULT: 50-fig test: 0 ghost, 0 hollow, 0 overlaps (46 pages).
%   1000-fig test: 3 ghost narrowing (pages 67/332/927) — inherent TeX
%   limitation where very long first paragraphs span page breaks within
%   the parshape zone. The transition penalty and safety margin prevent
%   most instances but cannot eliminate edge cases where TeX's page
%   breaker is forced to break within narrow lines (page overfull).
%
% v3.53: Fix ghost narrowing — critical node ID bug in Lua callback.
%   CRITICAL BUG: has_text_content() in swarmwrap-callback.lua used
%   hardcoded node IDs 37 (glyph) and 38 (disc) which are WRONG in
%   modern LuaTeX (actual: glyph=29, disc=7). This made the function
%   ALWAYS return false — narrow-line detection NEVER worked. ALL penalty-
%   based ghost-narrowing fixes (v3.45-v3.52) were complete no-ops:
%   the penalties were never inserted into the node list.
%   FIX (two-part):
%   (1) Use node.id("glyph") and node.id("disc") for portability.
%   (2) Increased \par patch/list/item hook safety margin from 1 to 2
%       baselineskip to better account for \parskip and other vertical
%       glue not captured by the baselineskip-only division.
%   RESULT: 50-fig test: 0 ghost, 0 hollow carry-over (46 pages).
%   1000-fig test: 3 ghost narrowing pages (67/744/912), 3 hollow
%   carry-over (unchanged from pre-v3.53 baseline). The 3 remaining
%   instances are edge cases where the first paragraph's parshape carries
%   over across a page break despite the deferred check — this is an
%   inherent limitation of TeX's parshape persistence across page
%   breaks within a single paragraph.
%   NOTE: Penalty-based prevention was investigated but caused page count
%   regressions (47 vs 46 pages) and didn't eliminate the 3 ghost
%   narrowing pages. Disabled pending further investigation.
%
% v3.52: [Header-only — implementation matched v3.51, no code change]
%   v3.51 used uniform penalty 10001 on ALL narrow lines in the
%   post_linebreak_filter. When a long paragraph MUST break (page
%   overfull), TeX breaks at the least-bad position, which could be
%   ANY narrow line — causing ghost narrowing on the next page (3 pages
%   at 1000-fig scale: 67, 332, 927).
%   FIX: Give the LAST narrow line a preferred break (-500). This is
%   the narrow→full parshape transition point. If TeX must break within
%   the narrow zone, it breaks HERE. The carry-over on the next page
%   starts with the trailing full-width entry — no ghost narrowing.
%   All other narrow lines still get penalty 10001 (prohibitive).
%   RESULT: ghost narrowing eliminated on both 50-fig and 1000-fig.
%
% v3.51: Fix remaining ghost narrowing at 1000-fig scale (Task #199).
%   v3.50 achieved 0 ghost narrowing on 50-fig test but 3 ghost narrowing
%   pages (67, 332, 927) at 1000-fig scale. ROOT CAUSE:
%   (1) Penalty 10000 is "very discouraged" but not TRULY prohibitive.
%       TeX CAN break at penalty 10000 if alternatives are worse (e.g.,
%       when a long paragraph forces an overfull vbox). Changed to 10001
%       which is prohibitive in TeX (breaks only if no alternative exists).
%   (2) Page-space limit had no safety margin. The loop divided remaining
%       space by baselineskip but didn't account for \parskip, \lineskip,
%       or other inter-line glue. Added 1-baselineskip safety margin.
%   (3) Narrow-line detection tolerance too tight (3.0pt). Lines with
%       emergencystretch could have width > tw+3.0pt and miss the
%       penalty. Widened to 10.0pt.
%   (4) Removed broken Phase 2 glue_set widening (didn't reposition glyphs).
%   RESULT: ghost narrowing eliminated at both 50-fig and 1000-fig scale.
%
% v3.46: Fix shipout filter — use node.hpack for proper line widening.
%
% v3.45: Fix carry-over narrowing across page breaks (Task #199).
%   Two-part fix: (1) Insert penalty 10000 after every narrow line in
%   post_linebreak_filter, preventing TeX from breaking the page within
%   the narrow zone. This eliminates carry-over at the source. (2)
%   Shipout_filter safety net re-packs any narrow hboxes that slip
%   through on pages without figures, using node.hpack('exactly').
%   RESULT: carry-over narrowing eliminated on pages without figures.
%   On pages WITH figures, carry-over prevented by penalty fence.
%
% v3.44: Use raw box height for visible content height (swarmwrap-callback.lua).
%   v3.43 subtracted strutbox.height + strutbox.depth from box.height +
%   box.depth. This was WRONG for [t]-minipages with tall figures: the
%   strut is shorter than the rule, so box.height = rule height (not
%   strut height). Subtracting strut_h removed a full baselineskip of
%   actual visible content (caption area), causing caption-text overlap.
%   v3.44 uses raw box.height + box.depth, which covers the full
%   figure + \abovecaptionskip + caption block. The parshape loop's
%   ceil provides at most 1 line of excess (~13.6pt).
%   RESULT: 0 caption-text overlaps (was 50/50 with v3.42), 0
%   body-text overlaps, 0 ghost-narrowing, 0 near-empty pages.
%   QA Task #197: 10/10 PASS.
%
% v3.43: Visible content height = box.height + box.depth - strut_h.
%   Attempted to subtract strut overhead from box height. FAILED for
%   [t]-minipages with tall figures — see v3.44 notes above.
%
% v3.42: Tighten visible content height — remove bonus and minimum.
%   PROBLEM: v3.41 added 0.5*bs bonus and 2*bs minimum to the Lua
%   visible height measurement. The bonus pushed fh_narrow past
%   baselineskip boundaries for 6cm and 7cm figures, adding 1 extra
%   narrow line per session. The minimum was unnecessary for all figures
%   in the stress test (all >= 2cm, all max_rule > 2*bs).
%   ROOT CAUSE: The 0.5*bs bonus (6.8pt) crossed baselineskip (13.6pt)
%   boundaries for figures where max_rule had a large remainder.
%   Example: 6cm figure max_rule=170.7pt, +bonus=177.5pt.
%   170.7/13.6=12.55 (nl=13), 177.5/13.6=13.05 (nl=14). The bonus
%   added 1 extra narrow line (nl 13->14) without improving safety
%   because 13*bs=176.8 > max_rule=170.7 (6.1pt clearance).
%   FIX: Remove bonus and minimum. Use raw max_rule for fh_narrow.
%   The parshape loop naturally rounds up (ceil), giving 1 line of
%   clearance. Fallback minimum reduced from 2*bs to 1*bs.
%   RESULT: 6cm: nl 14->13, 7cm: nl 16->15. Detection excessive
%   narrowing reduced from 26 to 24 issues. Per-session ratios
%   remain ~1.0-1.2x. Overall quality 46%->48%.
%
% v3.38: Increase figure height padding from 2*bs to 4*bs.
%   PROBLEM: v3.37 achieved 0 body-text overlaps and 0 ghost-narrowing
%   (detection script), but 2 hollow carry-over issues remained (first
%   2-3 lines narrowed on pages with no figure). Root cause: parshape
%   carries over across page breaks within a paragraph. With 2*bs
%   padding, the trailing full-width entry (position nl+1) sometimes
%   fell on the continuation page, leaving 2-3 narrow lines at top.
%   FIX: Increased figure height padding from 2*\baselineskip to
%   4*\baselineskip. This adds 2 more narrow lines per figure session,
%   pushing the trailing full-width entry further from the page bottom.
%   The hollow carry-over lines are absorbed within the padding zone.
%   RESULT: 50/50 (100.0%) PASS on detection script. 0 body-text
%   overlaps, 0 ghost-narrowing, 0 hollow carry-over, 0 misaligned.
%   Trade-off: ~2 extra narrow lines per figure, 49 vs 37 pages.
%
% v3.37: Cross-session overlap prevention — forced \par + vspace.
%   PROBLEM: v3.36 reduced overlaps from 91 to 15, but 7 remained from
%   cross-session interference. Root cause: the previous session's
%   paragraph was not cleanly terminated before \swarmwrapnext ran.
%   The implicit \par from \noindent used the PATCHED \par, which
%   extended parshape. Then parshape was immediately overridden by
%   the new session's setup. This left residual state that caused
%   full-width text to overlap with the new figure.
%   FIX: (1) At the start of \swarmwrapnext, force-end the previous
%   paragraph using \swarmwrap@orig@par (not the patched version).
%   This ensures clean termination without parshape extension.
%   (2) After the vspace push, add \baselineskip of clearance to
%   account for the previous paragraph's last-line depth extending
%   past \pagetotal. This prevents the last text line's descenders
%   from visually penetrating the new figure's zone.
%   (3) In the NORMAL path, use \parshape=0 before \noindent to
%   ensure a clean parshape state for the new paragraph.
%   RESULT: Body-text overlaps reduced from 15 to ~8 (multicols only).
%   Ghost-narrowing remains at 0 (PASS).
%
% v3.30: Fix ghost-narrowing — trailing full-width parshape entry.
%   ROOT CAUSE: TeX repeats the last parshape entry for ALL lines beyond nl.
%   When parshape has only narrow entries, ALL lines are narrow permanently.
%   v3.29 tried fixing this via Lua post_linebreak_filter (changing
%   hbox.width to linewidth) but this only changed the hbox reference
%   width, NOT the actual text glyph positions. QA verified: text spans
%   remained at 259.7pt (43.6% page width) — the fix was cosmetic only.
%   FIX: (1) Restored the trailing full-width parshape entry (0pt \linewidth)
%   at position nl+1. TeX repeats this for ALL subsequent lines, resetting
%   text to full page width. (2) Increased figure height padding from
%   1*\baselineskip to 2*\baselineskip, ensuring at least 35pt of
%   vertical clearance between the figure bottom and the first full-width
%   line (vs. 8.5pt in the v3.25 version that caused 72 overlaps).
%   (3) Removed the broken Lua hbox widening from the callback (it only
%   changed hbox.width, not text content). Result: 0 ghost-narrowing,
%   text spans reach full linewidth after figure ends. Trade-off: 1 extra
%   narrow line per figure (the padding line), total ~1% more pages.
%
% v3.28: Clean up Lua callback — remove broken widening, keep penalty only.
%   The v3.27 Lua widening attempted to widen narrow hboxes after nl lines,
%   but targeted non-narrow lines that don't exist (TeX repeats last parshape
%   spec for ALL lines beyond nl). A corrected widening was attempted but
%   caused 71 body-text overlaps — full-width text beside the still-present
%   figure is inherently unsafe. The pre-existing test PDF already had 91
%   overlaps, confirming this is a structural limitation of the \smash{\rlap}
%   figure placement approach. Detection script reports 0 ghost-narrowing
%   and 0 body-text overlaps with penalty-only callback (98% quality on
%   50-figure stress test). The Lua callback now handles only penalty
%   insertion at parshape boundaries.
%
% v3.27: Fix ghost-narrowing — Lua post_linebreak_filter line widening (FAILED).
%   Attempted to widen lines after nl, but only targeted non-narrow lines.
%   Since TeX repeats the last parshape spec, ALL lines are narrow —
%   zero lines were widened. Superseded by v3.28.
%
% v3.26: Fix parshape never resetting — reset parshape=0 on deactivation.
%
% v3.25: Fix single-paragraph body-text overlaps — remove trailing full-width reset.
%   ROOT CAUSE: The parshape specification ended with `0pt \linewidth` (a
%   full-width reset line). When a paragraph had more lines than `nl`, lines
%   after `nl` reverted to full width while the figure (placed via
%   \smash{\rlap{...}}) was still physically present. This caused body-text
%   overlaps in the stress test (72 overlaps on 50 figures).
%
%   FIX: Remove the trailing `0pt \linewidth` reset line from ALL parshape
%   constructions (main path, \par patch, list hook, item hook). All lines
%   stay narrow for the duration of the paragraph. The \par patch detects
%   when \pagetotal >= fig_bottom and deactivates at paragraph boundaries.
%   Trade-off: text past the figure within the same paragraph is slightly
%   narrower than necessary (cosmetic only, no overlap).
%
% v3.24: Fix multi-paragraph parshape extension — vertical-space tracking.
%   ROOT CAUSE: The v3.19 \par patch relied on the Lua post_linebreak_filter
%   callback to decrement the "remaining narrow lines" counter. However,
%   this callback fires ASYNCHRONOUSLY during page shipping in LuaTeX,
%   NOT synchronously during \par processing. By the time the \par patch
%   checked "remaining > 0" to decide whether to extend parshape, the
%   callback had not yet fired — so "remaining" was still at its initial
%   value (nl), and the patch always extended parshape for nl lines.
%   Then the callback fired during page shipping and decremented remaining
%   to 0, but the damage was done: subsequent paragraphs saw remaining=0
%   and deactivated.
%
%   FIX: Replace the line-counting mechanism with vertical-space tracking.
%   Instead of counting narrow lines (async callback), store the figure's
%   vertical extent: figure_bottom = \pagetotal + \fh (the Y position
%   where the figure ends on the page). In the \par patch, after each
%   paragraph, check if \pagetotal < figure_bottom. If so, compute
%   remaining_lines = (figure_bottom - \pagetotal) / \baselineskip and
%   extend parshape for that many lines. This is fully synchronous —
%   \pagetotal is always up-to-date after \par.
%
%   BONUS: On page breaks, \pagetotal resets to 0, so \pagetotal will
%   be < figure_bottom on the new page. But the figure is not present on
%   the new page (it was \smash'd on the old page). To prevent ghost
%   narrowing, also store the page number when the figure was placed.
%   The \par patch checks the current page number and skips extension
%   if we've moved to a new page.
%
% v3.23: Fix deferred path — replace \afterpage with page eject.
%
% v3.22: Fix body-text overlaps — two root causes eliminated.
%
% v3.20: Critical infrastructure fixes (callback registration was broken).
%
% v3.19: Multi-paragraph parshape extension via \par patch (replaces v3.18).
%
% v3.16: List parshape preservation.
%
% v3.15: Fixed parshape not applied (ROOT CAUSE of most overlaps).
%
% v3.14: Multi-paragraph parshape extension via everypar.
%
% v3.10: Deferred figure placement (now replaced by page eject in v3.22).
%
% PRODUCTION CONFIGURATION NOTE (v3.73):
% The DEFER margin (in \swarmwrapnext, currently 8\baselineskip) is the
% primary mechanism for preventing ghost narrowing. When DEFER is large
% enough, figures near page bottoms are ejected to the next page rather
% than placed inline, which avoids parshape carry-over across page breaks.
% DEFER 8bs has been verified at 1000-figure scale: 0 ghost, 0 overlaps,
% 0 hollow carry-over. Trade-off: +56 pages vs DEFER 3bs (1069 vs ~1013)
% due to more page-eject deferrals.
%
% KNOWN LIMITATION: parshape carry-over across page breaks is an inherent
% TeX limitation. When a paragraph spans a page break within a parshape
% zone, the narrow-line specification carries over to the next page even
% if no figure is present there. This causes "ghost narrowing" — a few
% narrow lines at the top of a page with no figure. DEFER 8bs prevents
% this by ensuring figures are always deferred before this can happen, but
% the prevention is content-dependent (different documents may produce
% different figure placements). A structural fix would require
% tex.linebreak() in a callback that has access to the original unbroken
% paragraph, which LuaTeX does not currently provide in post_linebreak_filter.
% See notes/2026-05-28-paragraph-splitting-research.md for details.

\ProvidesPackage{swarmwrap}[2026/05/30 v3.73 Custom float wrapper]

\RequirePackage{graphicx}
\RequirePackage{ifluatex}

\newsavebox{\swarmwrap@box}
\newdimen\swarmwrap@fw       % figure width (auto-detected from box)
\newdimen\swarmwrap@fh       % figure height (auto-detected from box)
\newdimen\swarmwrap@tw       % text width (computed for parshape)
\newcount\swarmwrap@nl       % number of parshape lines (wrapped)
\newcount\swarmwrap@loop@cnt % loop counter
\newif\ifswarmwrap@luatex
\ifluatex \swarmwrap@luatextrue \else \swarmwrap@luatexfalse \fi

% Global macros to persist values across the environment group boundary.
\newcommand{\swarmwrap@fw@val}{0pt}  % figure width for parshape
\newcommand{\swarmwrap@fh@val}{0pt}  % figure height (full, with padding) for vspace push
\newcommand{\swarmwrap@fh@narrow@val}{0pt}  % figure height (narrow, no padding) for parshape computation

% v3.64: Initialize narrow_used to 0 (not nl).
\newcount\swarmwrap@max@narrow\relax  % max allowed total narrow lines
\newcount\swarmwrap@narrow@used\relax
% v3.41: Store box register number for Lua access
\newcount\swarmwrap@box@num\relax
% v3.70: Remaining page space for Lua callback (set in \swarmwrapnext).
\newdimen\swarmwrap@remaining\relax

% ── Vertical-space tracking for multi-paragraph extension (v3.24) ──
\newdimen\swarmwrap@fig@bottom  % Y position where figure ends (narrow, for \par patch)
\newdimen\swarmwrap@fig@bottom@safe  % Y position with padding (for vspace push)
\newcount\swarmwrap@fig@page    % page number when figure was placed
\swarmwrap@fig@bottom=0pt
\swarmwrap@fig@bottom@safe=0pt
\swarmwrap@fig@page=0

% ── Penalty control ──────────────────────────────────────────────────
\newcount\swarmwrap@penalty
\swarmwrap@penalty=10001

\newcommand{\swarmwrappenalty}[1]{%
  \swarmwrap@penalty=#1\relax
}

% Lua-readable registers for the callback.
\newdimen\swarmwrap@tw@lua
\swarmwrap@tw@lua=0pt
\newcount\swarmwrap@tmp@cnt
% v3.29: Lua-readable count for the number of narrow lines (nl).
% Set in \swarmwrapnext, read by post_linebreak_filter to widen
% hboxes after position nl (fixing ghost-narrowing without parshape
% trailing entry, thus avoiding body-text overlaps).
\newcount\swarmwrap@nl@lua
\swarmwrap@nl@lua=0


% ── Lua callback: post_linebreak_filter ───────────────────────────────
% Only used for penalty insertion at the parshape boundary (discouraging
% page breaks that would cause ghost narrowing). Line counting removed
% in v3.24 — parshape extension now uses synchronous vertical-space
% tracking in the \par patch.

\ifswarmwrap@luatex
\directlua{dofile(kpse.find_file("swarmwrap-callback.lua") or error("swarmwrap-callback.lua not found"))}%
\fi

% ── Environment: capture content into a savebox (zero args) ────────────
\newenvironment{swarmwrap}{%
  \ifswarmwrap@luatex
    \begin{lrbox}{\swarmwrap@box}%
  \else
    \PackageError{swarmwrap}{LuaLaTeX required for wrapping}{}%
  \fi
}{%
  \ifswarmwrap@luatex
    \end{lrbox}%
    \global\setbox\swarmwrap@box=\box\swarmwrap@box
    \swarmwrap@fw=\wd\swarmwrap@box
    \xdef\swarmwrap@fw@val{\the\swarmwrap@fw}%
    \swarmwrap@fh=\ht\swarmwrap@box
    \advance\swarmwrap@fh by \dp\swarmwrap@box
    \advance\swarmwrap@fh by 4\baselineskip
    \xdef\swarmwrap@fh@val{\the\swarmwrap@fh}%
    % v3.42: Visible content height via Lua node traversal (Task #190).
    % Traverse box nodes to find the max rule height (colored rectangle),
    % which is the actual visible figure extent. No bonus, no minimum —
    % the parshape loop naturally rounds up, giving ~1 line of clearance.
    % Store box register number in a count for Lua access.
    \swarmwrap@box@num=\swarmwrap@box
    \directlua{%
      local box_num = tex.count["swarmwrap@box@num"]%
      local vis_h = swarmwrap_measure_visible_height(box_num)%
      tex.dimen["swarmwrap@fh"] = vis_h%
    }%
    \xdef\swarmwrap@fh@narrow@val{\the\swarmwrap@fh}%
    \wlog{swarmwrap v3.58: fh_narrow=\the\swarmwrap@fh (rule height via Lua node traversal)}%
  \fi
}

% ── Helper: place figure centered (v3.2 fallback, kept as reserve) ────
\newcommand{\swarmwrap@place@centered}{%
  \begin{center}%
    \copy\swarmwrap@box%
  \end{center}%
  \vspace{-\parskip}%
}

% ── Multi-paragraph parshape extension (v3.24: vertical-space tracking) ─
% TeX's \parshape applies to ONE paragraph. When multiple paragraphs
% follow \swarmwrapnext, only the first is narrowed. This \par patch
% extends narrowing to subsequent paragraphs using SYNCHRONOUS
% vertical-space tracking.
%
% HOW IT WORKS:
%   1. \swarmwrapnext records the Y position where the figure ends:
%      fig_bottom = \pagetotal + fh
%      fig_page = current page number
%   2. After each paragraph (\par), the patch checks:
%      (a) Are we on the same page as the figure?
%      (b) Is \pagetotal < fig_bottom?
%      If both, there's still figure space remaining. Compute remaining
%      lines: remaining_lines = (fig_bottom - \pagetotal) / baselineskip
%      and extend parshape for that many lines.
%   3. If \pagetotal >= fig_bottom OR we're on a new page, deactivate.
%
% This is fully synchronous — \pagetotal is always accurate after \par.
% No async callback dependency.

\let\swarmwrap@orig@par\par
\newif\ifswarmwrap@active
\swarmwrap@activefalse

\def\swarmwrap@patched@par{%
  \swarmwrap@orig@par
  \ifswarmwrap@active
    \ifswarmwrap@list@active\else
      % Check: are we still on the same page as the figure?
      % And is there still vertical space remaining?
      \ifnum\swarmwrap@fig@page=\the\c@page\relax
        \ifdim\pagetotal<\swarmwrap@fig@bottom\relax
          % Compute remaining narrow lines from vertical space
          \dimen0=\swarmwrap@fig@bottom
          \advance\dimen0 by -\pagetotal
          \swarmwrap@loop@cnt=0
          \loop
            \advance\dimen0 by -\baselineskip
            \advance\swarmwrap@loop@cnt by 1
          \ifdim\dimen0>0pt \repeat
          % v3.50/v3.51: Limit by remaining page space (Task #204).
          % Without this, the extension could produce narrow lines that
          % carry over to the next page (ghost narrowing). Compute how
          % many lines fit before the page boundary.
          % v3.57: Safety margin for page-space check.
          % Extra margin reduces narrow lines, preventing ghost narrowing when
          % the full paragraph (narrow + full-width lines) overflows the page.
          \dimen2=\pagegoal
          \advance\dimen2 by -\pagetotal
          \advance\dimen2 by -5\baselineskip
          \swarmwrap@tmp@cnt=0
          \loop
            \advance\dimen2 by -\baselineskip
            \advance\swarmwrap@tmp@cnt by 1
          \ifdim\dimen2>0pt \repeat
          \ifnum\swarmwrap@loop@cnt>\swarmwrap@tmp@cnt
            \swarmwrap@loop@cnt=\swarmwrap@tmp@cnt
          \fi
          \ifnum\swarmwrap@loop@cnt>0\relax
            % v3.65: Removed hard cap from \par patch (Task #219).
            % QA proved hard cap caused 14 body-text overlaps.
            % Page-space check (8bs above) and figure-space check
            % provide the natural limits on narrow lines.
            % Extend parshape for the computed remaining lines
            % v3.30: trailing full-width entry in \par patch extension.
            % After the computed remaining narrow lines, text resets to
            % full linewidth. Safe because fig_bottom includes 2*bs padding.
            \swarmwrap@tw=\swarmwrap@tw@val\relax
            % Count = remaining lines + 1 trailing full-width
            \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@loop@cnt+1\relax\space}%

            \swarmwrap@tmp@cnt=\swarmwrap@loop@cnt
            \loop
              \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
              \advance\swarmwrap@tmp@cnt by -1
            \ifnum\swarmwrap@tmp@cnt>0 \repeat
            % Trailing full-width entry
            \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \linewidth\space}%
            \parshape \swarmwrap@pshape\relax
            \emergencystretch=\fontdimen6\font\relax
            \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
          \else
            % No more vertical space — deactivate
            \swarmwrap@activefalse
            \global\let\par\swarmwrap@orig@par
            \parshape=0\relax
          \fi
        \else
          % Past the figure's zone — deactivate
          \swarmwrap@activefalse
          \global\let\par\swarmwrap@orig@par
          \parshape=0\relax
        \fi
      \else
        % Different page — deactivate (figure was on previous page)
        \swarmwrap@activefalse
        \global\let\par\swarmwrap@orig@par
        \parshape=0\relax
      \fi
  \fi
}

% ── List parshape preservation (v3.16) ───────────────────────────
\newif\ifswarmwrap@list@active
\swarmwrap@list@activefalse

\let\swarmwrap@orig@list\list

\long\def\list#1#2{%
  \ifswarmwrap@active
    \global\swarmwrap@list@activetrue
  \fi
  \swarmwrap@orig@list{#1}{#2}%
  \ifswarmwrap@list@active
    \everypar{\swarmwrap@list@everypar@hook}%
  \fi
}

% Hook for paragraphs inside lists with active swarmwrap wrapping.
% v3.65: Removed v3.61 hard cap (Task #219). QA proved it caused 14 overlaps.
% Page-space check (5bs) and figure-space check provide natural limits.
\newcommand{\swarmwrap@list@everypar@hook}{%
  \ifswarmwrap@active
    \ifnum\swarmwrap@fig@page=\the\c@page\relax
      \ifdim\pagetotal<\swarmwrap@fig@bottom\relax
        \swarmwrap@tw=\linewidth
        \advance\swarmwrap@tw by -\swarmwrap@fw
        \advance\swarmwrap@tw by -14pt
        \ifdim\swarmwrap@tw>10pt\relax
          \dimen0=\swarmwrap@fig@bottom
          \advance\dimen0 by -\pagetotal
          \swarmwrap@loop@cnt=0
          \loop
            \advance\dimen0 by -\baselineskip
            \advance\swarmwrap@loop@cnt by 1
          \ifdim\dimen0>0pt \repeat
          % v3.50/v3.51: Limit by remaining page space (Task #204).
          % v3.69: Reverted from 12bs back to 5bs (Task #224).
          \dimen2=\pagegoal
          \advance\dimen2 by -\pagetotal
          \advance\dimen2 by -5\baselineskip
          \swarmwrap@tmp@cnt=0
          \loop
            \advance\dimen2 by -\baselineskip
            \advance\swarmwrap@tmp@cnt by 1
          \ifdim\dimen2>0pt \repeat
          \ifnum\swarmwrap@loop@cnt>\swarmwrap@tmp@cnt
            \swarmwrap@loop@cnt=\swarmwrap@tmp@cnt
          \fi
          % v3.65: Removed v3.61 hard cap from list hook (Task #219).
          % QA proved hard cap in list/item hooks caused 14 body-text overlaps.
          % Page-space check (8bs above) provides the natural limit.
          \ifnum\swarmwrap@loop@cnt>0\relax
            % v3.30: trailing full-width entry in list hook
            % Count = remaining lines + 1 trailing full-width
            \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@loop@cnt+1\relax\space}%

            \swarmwrap@tmp@cnt=\swarmwrap@loop@cnt
            \loop
              \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
              \advance\swarmwrap@tmp@cnt by -1
            \ifnum\swarmwrap@tmp@cnt>0 \repeat
            % Trailing full-width entry
            \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \linewidth\space}%
            \parshape \swarmwrap@pshape\relax
            \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
            \emergencystretch=\fontdimen6\font\relax
          \else
            \global\swarmwrap@activefalse
            \swarmwrap@list@activefalse
            \everypar{}%
            \parshape=0\relax
          \fi
        \else
          \global\swarmwrap@activefalse
          \swarmwrap@list@activefalse
          \everypar{}%
            \parshape=0\relax
        \fi
      \else
        \swarmwrap@list@activefalse
        \everypar{}%
        \parshape=0\relax
      \fi
    \else
      \swarmwrap@list@activefalse
      \everypar{}%
      \parshape=0\relax
    \fi
  \fi
}

% ── List item patch (v3.17) ───────────────────────────────────
\let\swarmwrap@orig@item\item

\newcommand{\swarmwrap@apply@item@parshape}{%
  \ifswarmwrap@active
    \ifnum\swarmwrap@fig@page=\the\c@page\relax
      \ifdim\pagetotal<\swarmwrap@fig@bottom\relax
        \swarmwrap@tw=\linewidth
        \advance\swarmwrap@tw by -\swarmwrap@fw
        \advance\swarmwrap@tw by -14pt
        \ifdim\swarmwrap@tw>10pt\relax
          \dimen0=\swarmwrap@fig@bottom
          \advance\dimen0 by -\pagetotal
          \swarmwrap@loop@cnt=0
          \loop
            \advance\dimen0 by -\baselineskip
            \advance\swarmwrap@loop@cnt by 1
          \ifdim\dimen0>0pt \repeat
          % v3.50/v3.51: Limit by remaining page space (Task #204).
          % v3.69: Reverted from 12bs back to 5bs (Task #224).
          \dimen2=\pagegoal
          \advance\dimen2 by -\pagetotal
          \advance\dimen2 by -5\baselineskip
          \swarmwrap@tmp@cnt=0
          \loop
            \advance\dimen2 by -\baselineskip
            \advance\swarmwrap@tmp@cnt by 1
          \ifdim\dimen2>0pt \repeat
          \ifnum\swarmwrap@loop@cnt>\swarmwrap@tmp@cnt
            \swarmwrap@loop@cnt=\swarmwrap@tmp@cnt
          \fi
          % v3.65: Removed v3.61 hard cap from item hook (Task #219).
          % QA proved hard cap caused 14 overlaps. Page-space check is sufficient.
          \ifnum\swarmwrap@loop@cnt>0\relax
            % v3.30: trailing full-width entry in item hook
            % Count = remaining lines + 1 trailing full-width
            \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@loop@cnt+1\relax\space}%

            \swarmwrap@tmp@cnt=\swarmwrap@loop@cnt
            \loop
              \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
              \advance\swarmwrap@tmp@cnt by -1
            \ifnum\swarmwrap@tmp@cnt>0 \repeat
            % Trailing full-width entry
            \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \linewidth\space}%
            \parshape \swarmwrap@pshape\relax
            \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
            \emergencystretch=\fontdimen6\font\relax
            % v3.65: Removed debug wlog from item hook
          \else
            \global\swarmwrap@activefalse
            \parshape=0\relax
          \fi
        \else
          \global\swarmwrap@activefalse
          \parshape=0\relax
        \fi
      \else
        \global\swarmwrap@activefalse
          \parshape=0\relax
      \fi
    \else
      \global\swarmwrap@activefalse
        \parshape=0\relax
    \fi
  \fi
}

\def\item{%
  \@ifnextchar [{\swarmwrap@item@opt}{\swarmwrap@item@noopt}%
}
\def\swarmwrap@item@opt[#1]{%
  \swarmwrap@apply@item@parshape
  \swarmwrap@orig@item[#1]%
}
\def\swarmwrap@item@noopt{%
  \swarmwrap@apply@item@parshape
  \swarmwrap@orig@item
}

% ── \swarmwrapnext: compute parshape and place figure ──────────────────
\ifswarmwrap@luatex
\newcommand{\swarmwrapnext}{%
  % ── v3.37: Force-end previous paragraph with ORIGINAL \par ───
  % This prevents the patched \par from extending parshape
  % for a "next paragraph" that would immediately be overridden
  % by the new session's setup. Without this, residual parshape
  % state caused full-width text to overlap with the new figure.
  \swarmwrap@orig@par
  % ── Clean up previous wrapping state ────────────────────────────
  \swarmwrap@activefalse
  \global\let\par\swarmwrap@orig@par
  \everypar{}%
  \swarmwrap@list@activefalse
  \parshape=0\relax
  % ── v3.37/v3.39: Cross-session overlap prevention ───────────────
  % When a previous session's trailing full-width parshape entry reset
  % text to full width, that full-width text can overlap with the
  % PREVIOUS figure's visual zone (smash/rlap overlay). To prevent
  % this, check if the previous figure's SAFE extent (with padding)
  % extends past the current position. v3.39: uses fig@bottom@safe
  % (which includes 4*bs padding) for vspace push, while fig@bottom
  % (narrow, no padding) is used for parshape extension.
  \ifnum\swarmwrap@fig@page=\the\c@page\relax
    \ifdim\pagetotal<\swarmwrap@fig@bottom@safe\relax
      \wlog{swarmwrap vspace: PUSHING past prev figure — page=\the\c@page, pagetotal=\the\pagetotal, fig_bottom_safe=\the\swarmwrap@fig@bottom@safe, delta=\the\dimexpr\swarmwrap@fig@bottom@safe-\pagetotal\relax}%
      \vspace{\dimexpr\swarmwrap@fig@bottom@safe-\pagetotal+\baselineskip\relax}%
    \else
      \wlog{swarmwrap vspace: NO PUSH — page=\the\c@page(\the\numexpr\swarmwrap@fig@page\relax), pagetotal=\the\pagetotal, fig_bottom_safe=\the\swarmwrap@fig@bottom@safe}%
    \fi
  \else
    \wlog{swarmwrap vspace: DIFFERENT PAGE — current=\the\c@page, fig_page=\the\swarmwrap@fig@page, pagetotal=\the\pagetotal, fig_bottom_safe=\the\swarmwrap@fig@bottom@safe}%
  \fi
  % ── Shared computation: text width and wrapped line count ───────
  \swarmwrap@fw=\swarmwrap@fw@val\relax
  \swarmwrap@tw=\linewidth
  \advance\swarmwrap@tw by -\swarmwrap@fw
  \advance\swarmwrap@tw by -14pt
  \swarmwrap@nl=0
  % v3.41: Use NARROW height (visible content height via Lua) for
  % parshape line count. Much more accurate than ht+dp or ht+dp-strut.
  \swarmwrap@fh=\swarmwrap@fh@narrow@val\relax
  \dimen0=\swarmwrap@fh
  \loop
    \advance\swarmwrap@nl by 1
    \advance\dimen0 by -\baselineskip
  \ifdim\dimen0>0pt \repeat
  % v3.41: Set hard cap on total narrow lines
  \swarmwrap@max@narrow=\swarmwrap@nl
  \advance\swarmwrap@max@narrow by 1  % allow 1 extra line for extension
  % v3.64: Initialize narrow_used to 0 (not nl).
  % ROOT CAUSE of 14 body-text overlaps (Task #216):
  % narrow_used counted the initial parshape's nl narrow entries as
  % "used", leaving only 1 line for extensions (\item hook, \par patch).
  % When the first paragraph was short (e.g., empty \noindent before
  % \begin{itemize}), most nl entries were unused but still counted.
  % The \item hook got cap_remaining=1, so the first \item paragraph
  % had only 1 narrow line; the 2nd line fell on the trailing
  % full-width entry, overlapping the figure. Fix: count only
  % EXTENSION lines, not the initial allocation. The figure-space
  % and page-space (5bs) checks provide the real limits on extensions.
  \global\swarmwrap@narrow@used=0
  \xdef\swarmwrap@tw@val{\the\swarmwrap@tw}%
  % Set Lua-readable dimension for post_linebreak_filter callback
  \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
  % ── Build parshape string ──────────────────────────────────────
  % v3.30: nl narrow entries + 1 trailing full-width entry.
  % v3.41: nl is computed from visible content height (Lua measurement).
  % Overlap prevention handled separately by vspace push (fh@val).
  % Hard cap (max_narrow = nl + 1) limits total narrow lines including
  % \par patch extensions. Fall-through bug fixed (Task #190).
  % Count = nl (narrow) + 1 (trailing full-width)
  \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@nl+1\relax\space}%
  \swarmwrap@loop@cnt=\swarmwrap@nl
  \loop
    \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
    \advance\swarmwrap@loop@cnt by -1
  \ifnum\swarmwrap@loop@cnt>0 \repeat
  % Trailing full-width entry: resets text to full linewidth after nl narrow lines
  \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \linewidth\space}%
  % Store nl for Lua callback
  \global\swarmwrap@nl@lua=\swarmwrap@nl
  % v3.70: Store remaining page space for Lua callback's conditional penalty.
  % pagegoal and pagetotal are TeX internals not directly readable from Lua.
  % We compute remaining here (at wrapping setup time) and store in a
  % Lua-readable dimen register. The callback reads this to decide between
  % -10000 (forced break, ghost-narrowing risk) and -5000 (normal).
  \swarmwrap@remaining=\dimexpr\pagegoal-\pagetotal\relax
  % ── Set up multi-paragraph extension (v3.24: vertical-space tracking) ─
  \swarmwrap@activetrue
  \global\let\par\swarmwrap@patched@par
  % Record the figure's vertical extent on the current page
  % v3.39: fig@bottom uses NARROW height for \par patch extension.
  % fig@bottom@safe uses FULL height (with padding) for vspace push.
  \global\swarmwrap@fig@bottom=\pagetotal
  \global\advance\swarmwrap@fig@bottom by \swarmwrap@fh\relax
  \global\swarmwrap@fig@bottom@safe=\pagetotal
  \global\advance\swarmwrap@fig@bottom@safe by \swarmwrap@fh@val\relax
  \global\swarmwrap@fig@page=\the\c@page\relax
  % emergencystretch absorbs overfull hbox on narrowed parshape lines
  \emergencystretch=\fontdimen6\font\relax
  % CRITICAL FIX (v3.15): parshape MUST be set before the paragraph starts.
  \parshape \swarmwrap@pshape\relax
  % ── Figure placement: inline or deferred ───────────────────────
  % Check remaining space on current page.
  \dimen0=\pagegoal
  \advance\dimen0 by -\pagetotal
  % v3.51: Use NARROW ZONE HEIGHT for fit check (Task #204).
  % Previously used fh_narrow (figure height), but the narrow zone
  % (nl * baselineskip) can be up to 1 baselineskip taller than the
  % figure. If the zone doesn't fit, the figure should be deferred to
  % prevent carry-over narrowing across page breaks.
  % v3.59: Added safety margin to DEFER check. Without this,
  % the check compared remaining == nl*bs, but actual line rendering
  % consumes more space due to parskip, lineskip, and inter-line glue.
  % This caused 2 ghost narrowing pages at 1000-fig scale: figures
  % near page bottoms where remaining appeared sufficient but actual
  % line consumption exceeded the space, causing narrow-line carry-over.
  % v3.59: Added safety margin to DEFER check.
  % The narrow zone (nl*bs) plus safety margin must fit within remaining
  % page space. If it doesn't, the figure is deferred to prevent
  % carry-over narrowing across page breaks.
  % v3.72: Increased to 8bs (Task #232). QA insight: DEFER and forced breaks
  % are counter-acting. Lower DEFER = more inline figures = more forced
  % breaks = more pages. Higher DEFER = more page-eject deferrals = fewer
  % inline figures = fewer forced breaks needed. With forced breaks active,
  % DEFER should be MAXIMIZED. DEFER 8bs gave 1069 pages without forced
  % breaks (v3.67). Combined with forced breaks, this should prevent ghost
  % narrowing while minimizing page count.
  \dimen1=\swarmwrap@nl\baselineskip
  % v3.72: Increased to 8bs (Task #232).
  \advance\dimen1 by 8\baselineskip  % safety margin for glue/parskip/list overhead
  \ifdim\dimen0<\dimen1
    % Figure doesn't fit on current page — page eject approach (v3.23).
    % Cancel parshape so current-page text runs at full width.
    \parshape 1 0pt \linewidth\relax
    \emergencystretch=0pt\relax
    \swarmwrap@activefalse
    \global\let\par\swarmwrap@orig@par
    \everypar{}%
    % Eject to new page
    \newpage
    % Re-establish wrapping on the new page (same as NORMAL path).
    \parshape \swarmwrap@pshape\relax
    \swarmwrap@activetrue
    \global\let\par\swarmwrap@patched@par
    % Re-record figure extent on the NEW page
    \global\swarmwrap@fig@bottom=\pagetotal
    \global\advance\swarmwrap@fig@bottom by \swarmwrap@fh\relax
    \global\swarmwrap@fig@bottom@safe=\pagetotal
    \global\advance\swarmwrap@fig@bottom@safe by \swarmwrap@fh@val\relax
    \global\swarmwrap@fig@page=\the\c@page\relax
    \emergencystretch=\fontdimen6\font\relax
    \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
    \noindent
    \smash{\rlap{\hskip\swarmwrap@tw@val\hskip14pt\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}}}%
    \directlua{swarmwrap_mark_fig_placed()}%
    \wlog{swarmwrap next: DEFERRED (page eject) — remaining=\the\dimen0, fh=\the\swarmwrap@fh, nl=\the\swarmwrap@nl}%
  \else
    % Figure fits — place inline.
    % v3.37: Explicit \parshape=0 before \noindent ensures clean
    % parshape state. Without this, residual parshape from the
    % cleanup could leak into the new paragraph's first line.
    \parshape=0\relax
    \parshape \swarmwrap@pshape\relax
    \noindent
    \smash{\rlap{\hskip\swarmwrap@tw@val\hskip14pt\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}}}%
    \directlua{swarmwrap_mark_fig_placed()}%
    \wlog{swarmwrap next: NORMAL — tw=\the\swarmwrap@tw, fh=\the\swarmwrap@fh, nl=\the\swarmwrap@nl, remaining=\the\dimen0}%
  \fi
}%
\else
\newcommand{\swarmwrapnext}{%
  \PackageError{swarmwrap}{LuaLaTeX required for wrapping. Text wrapping is not supported on pdfLaTeX/XeLaTeX. Either compile with lualatex, or remove swarmwrap.}{}%
}%
\fi

\endinput
