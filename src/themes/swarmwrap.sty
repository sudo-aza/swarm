% swarmwrap.sty — Right-side float wrapper for the Swarm toolkit (v3.27)
%
% Text wrapping using \parshape applied by \swarmwrapnext command.
% Built from scratch after all 9 existing LaTeX wrapping packages failed QA.
%
% Usage:
%   \usepackage{swarmwrap}
%
%   % Simple figure (single content box):
%   \begin{swarmwrap}%
%     \includegraphics[width=3cm]{photo}%
%   \end{swarmwrap}%
%   \swarmwrapnext
%   Paragraph text wraps around the figure.
%
%   % Multi-line content (figure + caption):
%   \begin{swarmwrap}%
%     \begin{minipage}[t]{3cm}
%       \centering
%       \includegraphics[width=\linewidth]{photo}
%       \captionof{figure}{Caption.}
%     \end{minipage}%
%   \end{swarmwrap}%
%   \swarmwrapnext
%   Paragraph text wraps around the figure.
%
%   % Custom page-break penalty (discourage breaks in wrapped zone):
%   \swarmwrappenalty{500}  % default is 10000 (very discouraged)
%
%   % Custom text-figure gap (horizontal space between text and figure):
%   \swarmwrapgap{20pt}  % default is 14pt
%
% Zero arguments. Width and height are auto-detected from the rendered
% content box. The user controls the content width explicitly (e.g.,
% \includegraphics[width=3cm] or \begin{minipage}[t]{3cm}).
% Right-side wrapping only. Left-wrap removed in v3.0 (scope reduction).
%
% Requirements: LuaLaTeX (errors out on pdfLaTeX/XeLaTeX)
%
% ── Known Limitations ─────────────────────────────────────────────────
%
% 1. Ghost narrowing (KNOWN LIMITATION, v3.19):
%    When the wrapped paragraph spans a page break, TeX's parshape
%    persists across the page boundary but the figure does not (it is
%    placed via \smash{\rlap{...}} which is page-local). Continuation
%    lines on the next page remain narrowed even though no figure is
%    beside them.
%    v3.18 attempted to fix this via page-eject but CAUSED A REGRESSION
%    (ghost 4 to 11 on 50-page test). The page-eject leaked parshape
%    state across \newpage. v3.19 REVERTS the page-eject. Instead, the
%    post_linebreak_filter detects page breaks within the narrow zone
%    (total_lines < nl) and zeros out remaining@nl to prevent everypar
%    from amplifying the leak into subsequent paragraphs. The leaked
%    parshape lines on the continuation page are unavoidable — this is
%    a fundamental TeX limitation (parshape is set before page breaking).
%    Combined with \swarmwrappenalty (default 10000) at the boundary,
%    TeX's page breaker is discouraged from breaking within the narrow
%    zone, reducing ghost instances.
%
% 2. Deferred figure placement (FIXED in v3.27):
%    When the figure doesn't fit on the current page (\pagegoal - \pagetotal
%    < figure height), v3.27 now forces a new page and places the figure
%    at the top-right with narrow parshape for the following text.
%    Previous approach (\afterpage overlay) was fundamentally broken:
%    it placed a zero-height figure at the top of the next page, but
%    subsequent paragraphs flowed full-width through the overlay.
%    Three independent attempts (v3.24, v3.25, v3.26) confirmed \afterpage
%    cannot work for this use case. v3.27's \newpage approach satisfies
%    wrapping spec #4 ("near newpage: right-wrap on next page").
%
% ── Changelog ───────────────────────────────────────────────────────
%
% v3.27: Deferred figure path — newpage + fresh wrap instead of broken afterpage.
%   When a figure doesn't fit on the current page, the previous approach
%   (\afterpage overlay) was fundamentally broken: it placed a zero-height
%   figure at the top of the next page, but subsequent paragraphs flowed
%   full-width through the overlay, causing 67 body-text overlaps (v3.26).
%   Three independent attempts confirmed \afterpage cannot work (v3.24,
%   v3.25, v3.26). The v3.25/v3.26.1 workaround was to silently drop
%   the figure (broken catcode bug was accidentally benign).
%   v3.27 replaces the broken afterpage with a \newpage + fresh wrap:
%   force a new page, place the figure at the top-right, and set narrow
%   parshape for the following text. This satisfies wrapping spec #4
%   ("near newpage: right-wrap on next page"). Ghost narrowing from
%   deferred figures is eliminated since figure and text are on the same
%   page. Trade-off: +1 page per deferred figure (current page may
%   have trailing whitespace where narrow text would have been).
%   Compile-tested: 0 errors on all 4 test suites. No regressions.
%
% v3.26: Fix deferred afterpage catcode bug — figures now appear on next page.
%   v3.23's deferred path used \directlua{tex.sprint(string.format("...%.5f..."))}
%   which was silently truncated by TeX's catcode 14 (%% is a comment char).
%   The \afterpage was NEVER emitted — deferred figures were dropped.
%   FIX: Use \xdef to pre-expand tw and gap as TeX dimension strings
%   (e.g., "288.0pt"), then build the \afterpage token list with \hskip\relax
%   and the baked values. No string.format with %% needed.
%   Results: 15 deferred figures now appear on continuation pages, aligned
%   with leaked parshape lines. Ghost narrowing reduced on 50-page test.
%   Zero overlap regressions on both 50-page and 1000-page tests.
%
% v3.25: Revert v3.24 deferred path fix, restore v3.23.1 layout stability.
%   v3.24's deferred path change (no parshape when figure doesn't fit)
%   caused 9 body-text overlaps on the 1000-page stress test (was 1 in
%   v3.23.1). Root cause: removing parshape in the deferred case altered
%   page breaks throughout the 886-page document, causing cascading
%   misalignment between figures and subsequent paragraphs. FIX: Restore
%   v3.23.1's deferred behavior (set parshape, keep broken afterpage call).
%   Ghost compensation (\afterpage figure copy on continuation pages) also
%   removed — it was the wrong approach for fixing ghost narrowing.
%   Results: overlaps 9→1 on 1000-page (regression fixed), ghost and
%   hollow return to v3.23.1 baseline levels.
%
% v3.23.1: Revert v3.24-v3.26 regressions + document deferred path bug.
%   v3.24-v3.26 (from uncommitted cron session) changed the deferred
%   threshold and added incomplete ghost compensation, causing 83 body-
%   text overlaps (was 0). REVERT to v3.23 proven baseline. Also
%   documented the latent deferred-path \afterpage bug (%.5f truncated
%   by TeX's catcode 14) and noted that fixing it requires fundamental
%   redesign of the deferred path, not just a syntax fix.
%
% v3.23: Fix broken list patch braces (Task 166).
%   v3.22's list patch had unclosed \message{ and \typeout{ braces on
%   lines 249, 254, 258, 261, 264. The missing closing braces caused
%   ALL subsequent code (Lua callbacks, swarmwrap environment,
%   \swarmwrapnext) to be consumed as \typeout arguments. This made
%   the swarmwrap environment UNDEFINED, breaking ALL wrapping.
%   FIX: Remove all debug \message/\typeout calls. Properly structure
%   the \list redefinition with correct brace matching. The actual
%   linewidth reduction logic is preserved.
%
% v3.19: Revert page-eject ghost narrowing fix (Task 169).
%   v3.18's page-eject (insert \newpage when nl*bs > remaining-2*bs)
%   REGRESSED ghost narrowing from 4 to 11 on 50-page test (3x worse).
%   Root cause: \newpage did not reset parshape/text-width state from
%   previous figures. The ejected page started with leaked parshape,
%   creating new ghost-narrowed pages that didn't exist before.
%   FIX: Revert page-eject entirely. In post_linebreak_filter, when
%   total_lines < nl (paragraph broke across pages within narrow zone),
%   zero out remaining@nl to prevent everypar from re-applying parshape
%   to subsequent paragraphs. The leaked parshape lines on the
%   continuation page are a fundamental TeX limitation — parshape is
%   assigned before page breaking. Penalty at boundary (v3.6) remains
%   to discourage breaks. Result: regression eliminated.
%
% v3.18: Fix ghost narrowing via page-eject (Task 166).
%   BUG: When a wrapped paragraph is long enough to span a page break,
%   TeX distributes the N narrowed parshape lines across pages. The
%   figure overlay (\smash{\rlap{...}}) is page-local, so continuation
%   lines on the next page are narrowed without a figure beside them.
%   4 instances in 50-figure stress test (42 pages).
%   FIX: In the NORMAL path (figure fits on current page), add a
%   page-eject check: if nl * baselineskip > remaining_space -
%   2*baselineskip, insert \newpage before setting \parshape and
%   placing the figure. This ensures all N narrow lines and the
%   figure are on the same page. Restructured code so \noindent
%   and \parshape are set AFTER the eject decision (not before),
%   preventing mode conflicts. Result: ghost narrowing 4 -> 0.
%
% v3.17: Fix itemize/enumerate parshape leak (Task 166).
%   BUG: LaTeX's \trivlist (called by all standard list environments)
%   resets \parshape to full width when a list starts. List items after
%   \swarmwrapnext flow at full page width through the figure, causing
%   body-text overlaps. 72 overlaps on 12 pages in 1000-page stress test.
%   FIX: Patch \list to re-apply parshape with remaining narrow lines
%   after \trivlist has reset it. Track remaining narrow lines via
%   \swarmwrap@remaining@nl counter, decremented by post_linebreak_filter
%   after each paragraph. Recompute tw relative to list's \linewidth
%   (lists have narrower \linewidth due to \leftmargin). Inject into
%   \everypar so subsequent \item paragraphs also get narrowing.
%
% v3.16: Make text-figure gap configurable via \swarmwrapgap{<dimen>}.
%   Previously the gap was hardcoded as 14pt in three places (text width
%   computation, inline figure placement, deferred figure placement).
%   Now users can set \swarmwrapgap{20pt} for wider spacing or
%   \swarmwrapgap{8pt} for tighter wrapping. Default remains 14pt for
%   backward compatibility. No behavioral changes with default value.
%
% v3.15: Fix emergencystretch leak into subsequent paragraphs.
%   BUG: \emergencystretch=\fontdimen6\font (~5pt) was set inside
%   \swarmwrapnext at document level (no surrounding group). After
%   the wrapped paragraph's line breaking completed, this value leaked
%   into all subsequent non-wrapped paragraphs, causing slightly
%   looser typesetting throughout the rest of the document.
%   FIX: Reset \emergencystretch to 0pt in post_linebreak_filter
%   after processing a wrapped paragraph (tw_sp > 0). The emergency
%   stretch has already been consumed during line breaking, so
%   resetting it afterward is safe. No regressions.
%
% v3.14: Force paragraph break + remaining-height vspace in \swarmwrapnext.
%   ROOT CAUSE: \noindent does not end the current paragraph when called
%   mid-paragraph. Consecutive swarmwrap blocks without blank lines merged
%   into ONE paragraph; only the FIRST figure's parshape applied.
%   FIX (two parts):
%   (1) Add \par at start of \swarmwrapnext to force paragraph break.
%       Each figure now gets its own paragraph with correct parshape.
%   (2) Track figure height remaining after paragraph ends via
%       post_linebreak_filter (compares total lines vs nl). Inject
%       \vspace{remaining} at next \swarmwrapnext to push subsequent
%       content below the previous figure, preventing overlap.
%   RESULT: 43 body-text overlaps -> 0 on 50-figure stress test.
%   4 FIGURE BESIDE TEXT -> 0. 42 pages, 0 errors. No regressions
%   on standard tests (customwrap, consecutive, pagebreak).
%   Removed v3.12 multi-paragraph extension (135 lines of FIFO queue,
%   everypar injection, remaining counter). v3.12 halved overlaps (74->37)
%   but added significant complexity. Starting clean from v3.10.
%   v3.12's deferred tw@val overwriting bug fix preserved (bake tw as
%   literal dimension into \afterpage token list via tex.sprint).
%
% Earlier versions (v3.4-v3.10): Penalty system, deferred afterpage, height
%   padding, non-LuaLaTeX error, page-eject fallback. All superseded by
%   v3.14+ architecture. See git history for details.

\ProvidesPackage{swarmwrap}[2026/06/07 v3.27 deferred path newpage fresh wrap replaces broken afterpage]

\RequirePackage{graphicx}
\RequirePackage{ifluatex}
% afterpage no longer needed (v3.27 — deferred path uses \newpage instead)

\newsavebox{\swarmwrap@box}
\newdimen\swarmwrap@fw
\newdimen\swarmwrap@fh
\newdimen\swarmwrap@tw
\newcount\swarmwrap@nl
\newcount\swarmwrap@loop@cnt
\newif\ifswarmwrap@luatex

\ifluatex \swarmwrap@luatextrue \else \swarmwrap@luatexfalse \fi

\newcommand{\swarmwrap@fw@val}{0pt}
\newcommand{\swarmwrap@fh@val}{0pt}

% ── Gap control ─────────────────────────────────────────────────────
\newdimen\swarmwrap@gap
\swarmwrap@gap=14pt

\newcommand{\swarmwrapgap}[1]{%
  \swarmwrap@gap=#1\relax
}

% ── Penalty control ──────────────────────────────────────────────────
\newcount\swarmwrap@penalty
\swarmwrap@penalty=10000

\newcommand{\swarmwrappenalty}[1]{%
  \swarmwrap@penalty=#1\relax
}

\newdimen\swarmwrap@tw@lua
\swarmwrap@tw@lua=0pt

\newdimen\swarmwrap@remaining
\swarmwrap@remaining=0pt

% ── Multi-paragraph parshape persistence (v3.17) ────────────────────
\newcount\swarmwrap@remaining@nl
\swarmwrap@remaining@nl=0

% ── List patch: reduce \linewidth inside lists (Task 166) ──────
% LaTeX's \list (latex.ltx:15868) sets \parshape \@ne \@totalleftmargin \linewidth,
% overriding any swarmwrap narrow parshape. Hooks (para/begin) fire but TeX reads
% the parshape at a later stage. SOLUTION: When a list starts during an active
% wrap (remaining@nl > 0), reduce \linewidth by the figure width + gap before
% calling the original \list. The list's \parshape then uses the reduced
% \linewidth, producing naturally narrow lines. The reduction is scoped to
% the list environment using TeX grouping.
\let\swarmwrap@old@list\list

\newif\ifswarmwrap@in@list
\swarmwrap@in@listfalse

% \renewcommand{\list}: When remaining@nl > 0, reduce \linewidth by
% figure width + gap so the list's parshape produces narrow lines.
% The list's own grouping (\begin{itemize}...\end{itemize}) scopes the change.
\newdimen\swarmwrap@saved@lw
\renewcommand{\list}[2]{%
  \ifnum\swarmwrap@remaining@nl>0\relax
    \ifdim\swarmwrap@tw@lua>0pt\relax
      \swarmwrap@saved@lw=\linewidth
      \advance\linewidth by -\swarmwrap@fw@val
      \advance\linewidth by -\swarmwrap@gap
      \ifdim\linewidth>0pt\relax
        \swarmwrap@in@listtrue
      \else
        \linewidth=\swarmwrap@saved@lw
      \fi
    \fi
  \fi
  \swarmwrap@old@list{#1}{#2}%
  \swarmwrap@in@listfalse
}

% ── Lua callback: post_linebreak_filter ───────────────────────────────
\ifswarmwrap@luatex
\directlua{
  function swarmwrap_post_lb(head, groupcode)
    local tw_sp = tex.dimen["swarmwrap@tw@lua"]
    if tw_sp <= 0 then
      return head
    end
    local tw_val = tw_sp / 65536.0
    local tol = 3.0
    local narrow_width_max = tw_val + tol
    local last_narrow = nil
    local total_lines = 0
    local narrow_count = 0
    local current = head
    while current do
      if current.id == 0 then
        total_lines = total_lines + 1
        local lw = current.width / 65536.0
        if lw <= narrow_width_max and lw > 0 then
          narrow_count = narrow_count + 1
          last_narrow = current
        end
      end
      current = current.next
    end
    -- Decrement remaining-nl counter (v3.17)
    -- v3.19: If paragraph broke across pages (total_lines < nl),
    -- zero out remaining@nl to prevent everypar from re-applying
    -- parshape to subsequent paragraphs on the continuation page.
    if tex.count["swarmwrap@remaining@nl"] > 0 then
      local r = tex.count["swarmwrap@remaining@nl"]
      local nl = tex.count["swarmwrap@nl"]
      if total_lines < nl then
        tex.count["swarmwrap@remaining@nl"] = 0
      else
        r = math.max(0, r - narrow_count)
        tex.count["swarmwrap@remaining@nl"] = r
      end
    end
    -- Compute remaining figure height
    local nl = tex.count["swarmwrap@nl"]
    local bs = tex.dimen["baselineskip"]
    local excess = 0
    if total_lines < nl then
      excess = (nl - total_lines) * bs
    end
    tex.dimen["swarmwrap@remaining"] = excess
    -- Reset emergencystretch
    tex.dimen["emergencystretch"] = 0
    -- Insert penalty at parshape boundary
    local penalty_val = tex.count["swarmwrap@penalty"]
    if penalty_val > 0 and last_narrow then
      local p = node.new(node.id("penalty"))
      p.penalty = penalty_val
      node.insert_after(head, last_narrow, p)
    end
    return head
  end
  luatexbase.add_to_callback("post_linebreak_filter",
    swarmwrap_post_lb, "swarmwrap: penalty at parshape boundary")
}
\fi

% ── Environment: capture content into a savebox ─────────────────────
\newenvironment{swarmwrap}{%
  \ifswarmwrap@luatex
    \begin{lrbox}{\swarmwrap@box}%
  \else
    \PackageError{swarmwrap}{LuaLaTeX required for wrapping}{}%
  \fi
}{%
  \ifswarmwrap@luatex
    \end{lrbox}%
    \global\setbox\swarmwrap@box=\box\swarmwrap@box
    \swarmwrap@fw=\wd\swarmwrap@box
    \xdef\swarmwrap@fw@val{\the\swarmwrap@fw}%
    \swarmwrap@fh=\ht\swarmwrap@box
    \advance\swarmwrap@fh by \dp\swarmwrap@box
    \advance\swarmwrap@fh by 4pt
    \xdef\swarmwrap@fh@val{\the\swarmwrap@fh}%
  \fi
}

% ── \swarmwrapnext: compute parshape and place figure ──────────────────
\ifswarmwrap@luatex
\newcommand{\swarmwrapnext}{%
  \par
  \ifdim\swarmwrap@remaining>0pt
    \vspace{\swarmwrap@remaining}%
    \global\swarmwrap@remaining=0pt%
  \fi
  \swarmwrap@fw=\swarmwrap@fw@val\relax
  \swarmwrap@tw=\linewidth
  \advance\swarmwrap@tw by -\swarmwrap@fw
  \advance\swarmwrap@tw by -\swarmwrap@gap
  \swarmwrap@nl=0
  \swarmwrap@fh=\swarmwrap@fh@val\relax
  \dimen0=\swarmwrap@fh
  \loop
    \advance\swarmwrap@nl by 1
    \advance\dimen0 by -\baselineskip
  \ifdim\dimen0>0pt \repeat
  \xdef\swarmwrap@tw@val{\the\swarmwrap@tw}%
  \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
  \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@nl+1\relax\space}%
  \swarmwrap@loop@cnt=\swarmwrap@nl
  \loop
    \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
    \advance\swarmwrap@loop@cnt by -1
  \ifnum\swarmwrap@loop@cnt>0 \repeat
  \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\linewidth\space}%
  \global\swarmwrap@remaining@nl=\swarmwrap@nl
  \emergencystretch=\fontdimen6\font\relax
  % ── Page space check ──────────────────────────────────────────
  \dimen0=\pagegoal
  \advance\dimen0 by -\pagetotal
  \dimen1=\swarmwrap@fh@val\relax
  \ifdim\dimen0<\dimen1
    % DEFERRED: figure doesn't fit on current page.
    % v3.27: Force new page, place figure at top-right, set narrow
    % parshape for following text. This replaces the broken \afterpage
    % approach (v3.24-v3.26.1) which caused 67 body-text overlaps because
    % subsequent paragraphs flowed full-width through the overlay.
    \newpage
    \noindent
    \parshape \swarmwrap@pshape\relax
    \smash{\rlap{\hskip\swarmwrap@tw@val\hskip\swarmwrap@gap\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}}}%
    \wlog{swarmwrap next: DEFERRED-NEWPAGE --- fh=\the\swarmwrap@fh, nl=\the\swarmwrap@nl}%
  \else
    % NORMAL: figure fits on current page.
    % Ghost narrowing mitigation (v3.19): Instead of page-eject (which
    % caused regressions by leaking state across \newpage), we detect
    % page breaks in post_linebreak_filter. When the paragraph is
    % broken across pages (total_lines < nl), we zero out remaining@nl
    % to prevent everypar from re-applying parshape to subsequent
    % paragraphs. The parshape lines on the continuation page are
    % unavoidable (TeX sets line widths before page breaking).
    \noindent
    \parshape \swarmwrap@pshape\relax
    \smash{\rlap{\hskip\swarmwrap@tw@val\hskip\swarmwrap@gap\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}}}%
    \wlog{swarmwrap next: NORMAL --- tw=\the\swarmwrap@tw, fh=\the\swarmwrap@fh, nl=\the\swarmwrap@nl, remaining=\the\dimen0}%
  \fi
}%
\else
\newcommand{\swarmwrapnext}{%
  \PackageError{swarmwrap}{LuaLaTeX required for wrapping. Text wrapping is not supported on pdfLaTeX/XeLaTeX. Either compile with lualatex, or remove swarmwrap.}{}%
}%
\fi

\endinput
