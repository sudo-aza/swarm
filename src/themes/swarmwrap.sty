% swarmwrap.sty — Custom float wrapper for the Swarm toolkit (v2.2)
%
% Text wrapping using \parshape applied by \swarmwrapnext command.
% Built from scratch after all 9 existing LaTeX wrapping packages failed QA testing.
%
% Usage:
%   \usepackage{swarmwrap}
%
%   \begin{swarmwrap}[r]{3cm}{4cm}   % 3rd arg (height) kept for backward compat, ignored
%     \includegraphics[width=\linewidth]{photo}
%     \captionof{figure}{Caption.}
%   \end{swarmwrap}%
%   \swarmwrapnext
%   Paragraph text wraps around the figure.
%
% Requirements: LuaLaTeX (falls back to centered figure otherwise)
%
% Changes in v2.2:
%   - Page break detection: \swarmwrapnext checks remaining space on current page
%     (\pagegoal - \pagetotal). If less than figure height + \baselineskip,
%     inserts \newpage before the wrapped block. Prevents overfull vbox.
%   - Figure height stored as global macro \swarmwrap@fh@val for \swarmwrapnext.
%
% Changes in v2.1:
%   - Figure now extends DOWNWARD from text start (\raise adjusted by box \ht)
%     instead of upward from reference point (v2.0 bug)
%   - Line count uses \ht+\dp (total box height) not just \dp
%   - Figure top aligns with text ascender height for correct overlap
%
% Changes in v2.0:
%   - Height auto-detected from actual box dimensions
%   - \smash around \rlap/\llap prevents figure depth from corrupting interline spacing
%   - Trailing full-width parshape line resets excess lines to normal (LuaTeX fix)
%   - User-supplied height arg (3rd arg) accepted but ignored for backward compat
%
% Limitations:
%   - Cannot span page breaks (parshape limitation)
%   - One swarmwrap per paragraph
%   - Gracefully pushes wrapped block to next page if insufficient space

\ProvidesPackage{swarmwrap}[2026/05/17 v2.2 Custom float wrapper]

\RequirePackage{graphicx}
\RequirePackage{ifluatex}

\newsavebox{\swarmwrap@box}
\newdimen\swarmwrap@fw       % figure width (local, computation only)
\newdimen\swarmwrap@fh       % figure height (local, computation only)
\newdimen\swarmwrap@tw       % text width (local, computation only)
\newdimen\swarmwrap@ind      % indent (local, computation only)
\newcount\swarmwrap@nl       % number of lines (local, computation only)
\newcount\swarmwrap@loop@cnt % loop counter
\newif\ifswarmwrap@luatex
\newif\ifswarmwrap@right

\ifluatex \swarmwrap@luatextrue \else \swarmwrap@luatexfalse \fi

% Global macros to persist values across the environment group boundary.
% Set via \xdef (global \edef) in the environment end code.
% Read by \swarmwrapnext after the group closes.
\newcommand{\swarmwrap@pshape}{}     % fully-expanded parshape spec
\newcommand{\swarmwrap@tw@val}{0pt}   % text width for figure placement
\newcommand{\swarmwrap@ind@val}{0pt}  % indent for figure placement
\newcommand{\swarmwrap@fh@val}{0pt}  % figure height for page break detection

% ── Environment: save figure into box, compute parshape ─────────────────────

\newenvironment{swarmwrap}[3][r]{%
  \global\swarmwrap@righttrue
  \def\swarmwrap@tmp{#1}%
  \def\swarmwrap@cmp@l{l}%
  \def\swarmwrap@cmp@L{L}%
  \ifx\swarmwrap@tmp\swarmwrap@cmp@l\global\swarmwrap@rightfalse\fi
  \ifx\swarmwrap@tmp\swarmwrap@cmp@L\global\swarmwrap@rightfalse\fi
  \swarmwrap@fw=#2\relax
  % NOTE: #3 (height) is accepted for backward compatibility but IGNORED.
  % v2.0 auto-detects height from the actual rendered box.
  \ifswarmwrap@luatex
    \begin{lrbox}{\swarmwrap@box}\begin{minipage}[t]{\swarmwrap@fw}\centering
  \else
    \begin{figure}[htbp]\centering
    \PackageWarning{swarmwrap}{LuaLaTeX required for wrapping. Using float.}%
  \fi
}{%
  \ifswarmwrap@luatex
    \end{minipage}\end{lrbox}%
    % CRITICAL: Make the savebox global so it survives the environment group exit.
    % \newsavebox assigns are LOCAL to the current TeX group — without \global,
    % \end{swarmwrap} closes the group and the box reverts to empty.
    \global\setbox\swarmwrap@box=\box\swarmwrap@box
    % ── Auto-detect height from actual box ──────────────────────────────
    % v2.1: Use \ht + \dp (total box height) for line count.
    % The [t]-minipage puts the reference point at the first baseline. For a
    % \rule, the baseline is at the rule BOTTOM, so \ht = figure height (extends
    % ABOVE reference point) and \dp = caption depth (extends BELOW).
    % We need BOTH for the total height the figure occupies. The figure is placed
    % using \vtop which moves the reference point to the box TOP, so it extends
    % downward alongside the text.
    \swarmwrap@fh=\ht\swarmwrap@box
    \advance\swarmwrap@fh by \dp\swarmwrap@box
    \advance\swarmwrap@fh by \baselineskip  % one extra line for visual breathing room
    % Compute text width: \textwidth - figure width - gap
    \swarmwrap@tw=\textwidth
    \advance\swarmwrap@tw by -\swarmwrap@fw
    \advance\swarmwrap@tw by -12pt
    % Compute indent: 0pt for right wrap, fw+gap for left wrap
    \ifswarmwrap@right
      \swarmwrap@ind=0pt
    \else
      \swarmwrap@ind=\swarmwrap@fw
      \advance\swarmwrap@ind by 12pt
    \fi
    % Calculate number of lines from actual box height
    \swarmwrap@nl=0
    \dimen0=\swarmwrap@fh
    \loop
      \advance\swarmwrap@nl by 1
      \advance\dimen0 by -\baselineskip
    \ifdim\dimen0>0pt \repeat
    % ── Build parshape with trailing full-width line ────────────────────
    % In LuaTeX, lines beyond the parshape count reuse the LAST spec.
    % To make excess lines revert to normal width, we add a trailing
    % line spec with indent=0pt and width=\textwidth. The parshape
    % has N+1 entries: N narrowed lines + 1 full-width reset line.
    \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@nl+1\relax\space}%
    \swarmwrap@loop@cnt=\swarmwrap@nl
    \loop
      \xdef\swarmwrap@pshape{\swarmwrap@pshape\the\swarmwrap@ind\space\the\swarmwrap@tw\space}%
      \advance\swarmwrap@loop@cnt by -1
    \ifnum\swarmwrap@loop@cnt>0 \repeat
    % Trailing line: full width, no indent — resets excess lines to normal
    \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\textwidth\space}%
    % Also store text width, indent, and figure height as global macros
    \xdef\swarmwrap@tw@val{\the\swarmwrap@tw}%
    \xdef\swarmwrap@ind@val{\the\swarmwrap@ind}%
    \xdef\swarmwrap@fh@val{\the\swarmwrap@fh}%
  \else
    \end{figure}%
  \fi
}

% ── \swarmwrapnext: apply parshape + place figure ──────────────────────────
% Must be called immediately before the paragraph to wrap.
% Reads global macros set by the environment end code.

\ifswarmwrap@luatex
\newcommand{\swarmwrapnext}{%
  % ── Page break detection ────────────────────────────────────────
  % Check if the figure fits on the remaining space of the current page.
  % \pagegoal = total page height (from \topmargin + \textheight + \headheight etc.)
  % \pagetotal = vertical material already placed on this page.
  % If remaining space < figure height + baselineskip, push to next page.
  \dimen0=\pagegoal
  \advance\dimen0 by -\pagetotal
  \dimen1=\swarmwrap@fh@val\relax
  \ifdim\dimen0<\dimen1
    \newpage
  \fi
  \noindent
  \parshape \swarmwrap@pshape\relax
  \ifswarmwrap@right
    % Right wrap: overlay figure after the narrowed text area.
    % \smash{\rlap{...}} makes the figure overlay completely invisible to
    % TeX's line layout: zero width (\rlap), zero height and depth (\smash).
    % Without \smash, the figure box's depth (caption below baseline) would
    % corrupt interline spacing, adding ~75pt gap between lines 1 and 2.
    %
    % v2.1: The [t]-minipage puts the figure reference point at the rule BOTTOM.
    % So \ht = figure height (extends UP), \dp = caption depth (extends DOWN).
    % To make the figure extend DOWNWARD alongside text, we lower the box so the
    % figure TOP (= refpoint + \ht) aligns with the text ascender (= \ht\strutbox).
    % \raise dim = \ht\strutbox - \ht\swarmwrap@box (negative = lower the box).
    \smash{\rlap{\hskip\swarmwrap@ind@val\hskip\swarmwrap@tw@val\hskip6pt\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}}}%
  \else
    % Left wrap: overlay figure at the left indent position.
    % Same \raise adjustment for downward figure placement.
    \smash{\llap{\hskip\swarmwrap@ind@val\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}\hskip-6pt}}%
  \fi
}%
\else
\newcommand{\swarmwrapnext}{\relax}%
\fi

\endinput
