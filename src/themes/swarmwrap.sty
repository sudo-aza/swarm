% swarmwrap.sty — Right-side float wrapper for the Swarm toolkit (v3.25)
%
% Text wrapping using \parshape applied by \swarmwrapnext command.
% Built from scratch after all 9 existing LaTeX wrapping packages failed QA.
%
% Usage:
%   \usepackage{swarmwrap}
%
%   % Simple figure (single content box):
%   \begin{swarmwrap}%
%     \includegraphics[width=3cm]{photo}%
%   \end{swarmwrap}%
%   \swarmwrapnext
%   Paragraph text wraps around the figure.
%
%   % Multi-line content (figure + caption):
%   \begin{swarmwrap}%
%     \begin{minipage}[t]{3cm}
%       \centering
%       \includegraphics[width=\linewidth]{photo}
%       \captionof{figure}{Caption.}
%     \end{minipage}%
%   \end{swarmwrap}%
%   \swarmwrapnext
%   Paragraph text wraps around the figure.
%
%   % Custom page-break penalty (discourage breaks in wrapped zone):
%   \swarmwrappenalty{500}  % default is 10000 (very discouraged)
%
% Zero arguments. Width and height are auto-detected from the rendered
% content box. The user controls the content width explicitly (e.g.,
% \includegraphics[width=3cm] or \begin{minipage}[t]{3cm}).
% Right-side wrapping only. Left-wrap removed in v3.0 (scope reduction).
%
% Requirements: LuaLaTeX (errors out on pdfLaTeX/XeLaTeX)
%
% ── Known Limitations ─────────────────────────────────────────────────
%
% 1. Ghost narrowing on continuation pages:
%    When the wrapped paragraph spans a page break, TeX's parshape
%    persists across the page boundary but the figure does not (it is
%    placed via \smash{\rlap{...}} which is page-local). Continuation
%    lines on the next page remain narrowed even though no figure is
%    beside them. This is cosmetic only — no text overlaps the figure.
%    Mitigation: \swarmwrappenalty{N} inserts a penalty at the
%    boundary to discourage TeX from breaking there (default: 10000).
%    Affects only very long paragraphs that span page breaks.
%
% 2. Parshape leak into list items (PARTIALLY FIXED in v3.16):
%    When \swarmwrapnext is used before a list, subsequent \item
%    paragraphs now correctly maintain parshape narrowing. However,
%    if \swarmwrapnext is used INSIDE a list item, only that item
%    wraps — subsequent items are not narrowed (acceptable per spec).
%
% 3. Near-page figure:
%    When the figure doesn't fit on the current page, a page eject occurs.
%    Text on the current page runs at full width (no wrapping). On the
%    next page, the figure wraps right at the top-right and text wraps
%    beside it. This wastes space at the bottom of the current page but
%    eliminates body-text overlaps from continuation text.
%
% ── Changelog ───────────────────────────────────────────────────────
%
% v3.25: Fix single-paragraph body-text overlaps — remove trailing full-width reset.
%   ROOT CAUSE: The parshape specification ended with `0pt \linewidth` (a
%   full-width reset line). When a paragraph had more lines than `nl`, lines
%   after `nl` reverted to full width while the figure (placed via
%   \smash{\rlap{...}}) was still physically present. This caused body-text
%   overlaps in the stress test (72 overlaps on 50 figures).
%
%   FIX: Remove the trailing `0pt \linewidth` reset line from ALL parshape
%   constructions (main path, \par patch, list hook, item hook). All lines
%   stay narrow for the duration of the paragraph. The \par patch detects
%   when \pagetotal >= fig_bottom and deactivates at paragraph boundaries.
%   Trade-off: text past the figure within the same paragraph is slightly
%   narrower than necessary (cosmetic only, no overlap).
%
% v3.24: Fix multi-paragraph parshape extension — vertical-space tracking.
%   ROOT CAUSE: The v3.19 \par patch relied on the Lua post_linebreak_filter
%   callback to decrement the "remaining narrow lines" counter. However,
%   this callback fires ASYNCHRONOUSLY during page shipping in LuaTeX,
%   NOT synchronously during \par processing. By the time the \par patch
%   checked "remaining > 0" to decide whether to extend parshape, the
%   callback had not yet fired — so "remaining" was still at its initial
%   value (nl), and the patch always extended parshape for nl lines.
%   Then the callback fired during page shipping and decremented remaining
%   to 0, but the damage was done: subsequent paragraphs saw remaining=0
%   and deactivated.
%
%   FIX: Replace the line-counting mechanism with vertical-space tracking.
%   Instead of counting narrow lines (async callback), store the figure's
%   vertical extent: figure_bottom = \pagetotal + \fh (the Y position
%   where the figure ends on the page). In the \par patch, after each
%   paragraph, check if \pagetotal < figure_bottom. If so, compute
%   remaining_lines = (figure_bottom - \pagetotal) / \baselineskip and
%   extend parshape for that many lines. This is fully synchronous —
%   \pagetotal is always up-to-date after \par.
%
%   BONUS: On page breaks, \pagetotal resets to 0, so \pagetotal will
%   be < figure_bottom on the new page. But the figure is not present on
%   the new page (it was \smash'd on the old page). To prevent ghost
%   narrowing, also store the page number when the figure was placed.
%   The \par patch checks the current page number and skips extension
%   if we've moved to a new page.
%
% v3.23: Fix deferred path — replace \afterpage with page eject.
%
% v3.22: Fix body-text overlaps — two root causes eliminated.
%
% v3.20: Critical infrastructure fixes (callback registration was broken).
%
% v3.19: Multi-paragraph parshape extension via \par patch (replaces v3.18).
%
% v3.16: List parshape preservation.
%
% v3.15: Fixed parshape not applied (ROOT CAUSE of most overlaps).
%
% v3.14: Multi-paragraph parshape extension via everypar.
%
% v3.10: Deferred figure placement (now replaced by page eject in v3.22).

\ProvidesPackage{swarmwrap}[2026/05/23 v3.25 Custom float wrapper]

\RequirePackage{graphicx}
\RequirePackage{ifluatex}

\newsavebox{\swarmwrap@box}
\newdimen\swarmwrap@fw       % figure width (auto-detected from box)
\newdimen\swarmwrap@fh       % figure height (auto-detected from box)
\newdimen\swarmwrap@tw       % text width (computed for parshape)
\newcount\swarmwrap@nl       % number of parshape lines (wrapped)
\newcount\swarmwrap@loop@cnt % loop counter
\newif\ifswarmwrap@luatex
\ifluatex \swarmwrap@luatextrue \else \swarmwrap@luatexfalse \fi

% Global macros to persist values across the environment group boundary.
\newcommand{\swarmwrap@fw@val}{0pt}  % figure width for parshape
\newcommand{\swarmwrap@fh@val}{0pt}  % figure height for page break

% ── Vertical-space tracking for multi-paragraph extension (v3.24) ──
\newdimen\swarmwrap@fig@bottom  % Y position where figure ends on page
\newcount\swarmwrap@fig@page    % page number when figure was placed
\swarmwrap@fig@bottom=0pt
\swarmwrap@fig@page=0

% ── Penalty control ──────────────────────────────────────────────────
\newcount\swarmwrap@penalty
\swarmwrap@penalty=10000

\newcommand{\swarmwrappenalty}[1]{%
  \swarmwrap@penalty=#1\relax
}

% Lua-readable register for the current wrapped text width.
\newdimen\swarmwrap@tw@lua
\swarmwrap@tw@lua=0pt
\newcount\swarmwrap@tmp@cnt

% ── Lua callback: post_linebreak_filter ───────────────────────────────
% Only used for penalty insertion at the parshape boundary (discouraging
% page breaks that would cause ghost narrowing). Line counting removed
% in v3.24 — parshape extension now uses synchronous vertical-space
% tracking in the \par patch.

\ifswarmwrap@luatex
\directlua{dofile(kpse.find_file("swarmwrap-callback.lua") or error("swarmwrap-callback.lua not found"))}%
\fi

% ── Environment: capture content into a savebox (zero args) ────────────
\newenvironment{swarmwrap}{%
  \ifswarmwrap@luatex
    \begin{lrbox}{\swarmwrap@box}%
  \else
    \PackageError{swarmwrap}{LuaLaTeX required for wrapping}{}%
  \fi
}{%
  \ifswarmwrap@luatex
    \end{lrbox}%
    \global\setbox\swarmwrap@box=\box\swarmwrap@box
    \swarmwrap@fw=\wd\swarmwrap@box
    \xdef\swarmwrap@fw@val{\the\swarmwrap@fw}%
    \swarmwrap@fh=\ht\swarmwrap@box
    \advance\swarmwrap@fh by \dp\swarmwrap@box
    \advance\swarmwrap@fh by 4pt
    \xdef\swarmwrap@fh@val{\the\swarmwrap@fh}%
  \fi
}

% ── Helper: place figure centered (v3.2 fallback, kept as reserve) ────
\newcommand{\swarmwrap@place@centered}{%
  \begin{center}%
    \copy\swarmwrap@box%
  \end{center}%
  \vspace{-\parskip}%
}

% ── Multi-paragraph parshape extension (v3.24: vertical-space tracking) ─
% TeX's \parshape applies to ONE paragraph. When multiple paragraphs
% follow \swarmwrapnext, only the first is narrowed. This \par patch
% extends narrowing to subsequent paragraphs using SYNCHRONOUS
% vertical-space tracking.
%
% HOW IT WORKS:
%   1. \swarmwrapnext records the Y position where the figure ends:
%      fig_bottom = \pagetotal + fh
%      fig_page = current page number
%   2. After each paragraph (\par), the patch checks:
%      (a) Are we on the same page as the figure?
%      (b) Is \pagetotal < fig_bottom?
%      If both, there's still figure space remaining. Compute remaining
%      lines: remaining_lines = (fig_bottom - \pagetotal) / baselineskip
%      and extend parshape for that many lines.
%   3. If \pagetotal >= fig_bottom OR we're on a new page, deactivate.
%
% This is fully synchronous — \pagetotal is always accurate after \par.
% No async callback dependency.

\let\swarmwrap@orig@par\par
\newif\ifswarmwrap@active
\swarmwrap@activefalse

\def\swarmwrap@patched@par{%
  \swarmwrap@orig@par
  \ifswarmwrap@active
    \ifswarmwrap@list@active\else
      % Check: are we still on the same page as the figure?
      % And is there still vertical space remaining?
      \ifnum\swarmwrap@fig@page=\the\c@page\relax
        \ifdim\pagetotal<\swarmwrap@fig@bottom\relax
          % Compute remaining narrow lines from vertical space
          \dimen0=\swarmwrap@fig@bottom
          \advance\dimen0 by -\pagetotal
          \swarmwrap@loop@cnt=0
          \loop
            \advance\dimen0 by -\baselineskip
            \advance\swarmwrap@loop@cnt by 1
          \ifdim\dimen0>0pt \repeat
          \ifnum\swarmwrap@loop@cnt>0\relax
            % Extend parshape for the computed remaining lines
            \swarmwrap@tw=\swarmwrap@tw@val\relax
            \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@loop@cnt\relax\space}%

            \swarmwrap@tmp@cnt=\swarmwrap@loop@cnt
            \loop
              \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
              \advance\swarmwrap@tmp@cnt by -1
            \ifnum\swarmwrap@tmp@cnt>0 \repeat
            % v3.25: NO trailing full-width reset
            \parshape \swarmwrap@pshape\relax
            \emergencystretch=\fontdimen6\font\relax
            \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
          \else
            % No more vertical space — deactivate
            \swarmwrap@activefalse
            \global\let\par\swarmwrap@orig@par
          \fi
        \else
          % Past the figure's zone — deactivate
          \swarmwrap@activefalse
          \global\let\par\swarmwrap@orig@par
        \fi
      \else
        % Different page — deactivate (figure was on previous page)
        \swarmwrap@activefalse
        \global\let\par\swarmwrap@orig@par
      \fi
    \fi
  \fi
}

% ── List parshape preservation (v3.16) ───────────────────────────
\newif\ifswarmwrap@list@active
\swarmwrap@list@activefalse

\let\swarmwrap@orig@list\list

\long\def\list#1#2{%
  \ifswarmwrap@active
    \global\swarmwrap@list@activetrue
  \fi
  \swarmwrap@orig@list{#1}{#2}%
  \ifswarmwrap@list@active
    \everypar{\swarmwrap@list@everypar@hook}%
  \fi
}

% Hook for paragraphs inside lists with active swarmwrap wrapping.
\newcommand{\swarmwrap@list@everypar@hook}{%
  \ifswarmwrap@active
    \ifnum\swarmwrap@fig@page=\the\c@page\relax
      \ifdim\pagetotal<\swarmwrap@fig@bottom\relax
        \swarmwrap@tw=\linewidth
        \advance\swarmwrap@tw by -\swarmwrap@fw
        \advance\swarmwrap@tw by -14pt
        \ifdim\swarmwrap@tw>10pt\relax
          \dimen0=\swarmwrap@fig@bottom
          \advance\dimen0 by -\pagetotal
          \swarmwrap@loop@cnt=0
          \loop
            \advance\dimen0 by -\baselineskip
            \advance\swarmwrap@loop@cnt by 1
          \ifdim\dimen0>0pt \repeat
          \ifnum\swarmwrap@loop@cnt>0\relax
            \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@loop@cnt\relax\space}%

            \swarmwrap@tmp@cnt=\swarmwrap@loop@cnt
            \loop
              \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
              \advance\swarmwrap@tmp@cnt by -1
            \ifnum\swarmwrap@tmp@cnt>0 \repeat
            % v3.25: NO trailing full-width reset
            \parshape \swarmwrap@pshape\relax
            \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
            \emergencystretch=\fontdimen6\font\relax
          \else
            \global\swarmwrap@activefalse
            \swarmwrap@list@activefalse
            \everypar{}%
          \fi
        \else
          \global\swarmwrap@activefalse
          \swarmwrap@list@activefalse
          \everypar{}%
        \fi
      \else
        \swarmwrap@list@activefalse
        \everypar{}%
      \fi
    \else
      \swarmwrap@list@activefalse
      \everypar{}%
    \fi
  \fi
}

% ── List item patch (v3.17) ───────────────────────────────────
\let\swarmwrap@orig@item\item

\newcommand{\swarmwrap@apply@item@parshape}{%
  \ifswarmwrap@active
    \ifnum\swarmwrap@fig@page=\the\c@page\relax
      \ifdim\pagetotal<\swarmwrap@fig@bottom\relax
        \swarmwrap@tw=\linewidth
        \advance\swarmwrap@tw by -\swarmwrap@fw
        \advance\swarmwrap@tw by -14pt
        \ifdim\swarmwrap@tw>10pt\relax
          \dimen0=\swarmwrap@fig@bottom
          \advance\dimen0 by -\pagetotal
          \swarmwrap@loop@cnt=0
          \loop
            \advance\dimen0 by -\baselineskip
            \advance\swarmwrap@loop@cnt by 1
          \ifdim\dimen0>0pt \repeat
          \ifnum\swarmwrap@loop@cnt>0\relax
            \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@loop@cnt\relax\space}%

            \swarmwrap@tmp@cnt=\swarmwrap@loop@cnt
            \loop
              \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
              \advance\swarmwrap@tmp@cnt by -1
            \ifnum\swarmwrap@tmp@cnt>0 \repeat
            % v3.25: NO trailing full-width reset
            \parshape \swarmwrap@pshape\relax
            \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
            \emergencystretch=\fontdimen6\font\relax
          \else
            \global\swarmwrap@activefalse
          \fi
        \else
          \global\swarmwrap@activefalse
        \fi
      \else
        \global\swarmwrap@activefalse
      \fi
    \else
      \global\swarmwrap@activefalse
    \fi
  \fi
}

\def\item{%
  \@ifnextchar [{\swarmwrap@item@opt}{\swarmwrap@item@noopt}%
}
\def\swarmwrap@item@opt[#1]{%
  \swarmwrap@apply@item@parshape
  \swarmwrap@orig@item[#1]%
}
\def\swarmwrap@item@noopt{%
  \swarmwrap@apply@item@parshape
  \swarmwrap@orig@item
}

% ── \swarmwrapnext: compute parshape and place figure ──────────────────
\ifswarmwrap@luatex
\newcommand{\swarmwrapnext}{%
  % ── Clean up previous wrapping state ────────────────────────────
  \swarmwrap@activefalse
  \global\let\par\swarmwrap@orig@par
  \everypar{}%
  \swarmwrap@list@activefalse
  % ── Shared computation: text width and wrapped line count ───────
  \swarmwrap@fw=\swarmwrap@fw@val\relax
  \swarmwrap@tw=\linewidth
  \advance\swarmwrap@tw by -\swarmwrap@fw
  \advance\swarmwrap@tw by -14pt
  \swarmwrap@nl=0
  \swarmwrap@fh=\swarmwrap@fh@val\relax
  \dimen0=\swarmwrap@fh
  \loop
    \advance\swarmwrap@nl by 1
    \advance\dimen0 by -\baselineskip
  \ifdim\dimen0>0pt \repeat
  \xdef\swarmwrap@tw@val{\the\swarmwrap@tw}%
  % Set Lua-readable dimension for post_linebreak_filter callback
  \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
  % ── Build parshape string ──────────────────────────────────────
  \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@nl\relax\space}%
  \swarmwrap@loop@cnt=\swarmwrap@nl
  \loop
    \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
    \advance\swarmwrap@loop@cnt by -1
  \ifnum\swarmwrap@loop@cnt>0 \repeat
  % v3.25: NO trailing full-width reset — keeps all lines narrow to prevent
  % intra-paragraph body-text overlaps when paragraph is longer than nl.
  % ── Set up multi-paragraph extension (v3.24: vertical-space tracking) ─
  \swarmwrap@activetrue
  \global\let\par\swarmwrap@patched@par
  % Record the figure's vertical extent on the current page
  \global\swarmwrap@fig@bottom=\pagetotal
  \global\advance\swarmwrap@fig@bottom by \swarmwrap@fh\relax
  \global\swarmwrap@fig@page=\the\c@page\relax
  % emergencystretch absorbs overfull hbox on narrowed parshape lines
  \emergencystretch=\fontdimen6\font\relax
  % CRITICAL FIX (v3.15): parshape MUST be set before the paragraph starts.
  \parshape \swarmwrap@pshape\relax
  % ── Figure placement: inline or deferred ───────────────────────
  % Check remaining space on current page.
  \dimen0=\pagegoal
  \advance\dimen0 by -\pagetotal
  \dimen1=\swarmwrap@fh@val\relax
  \ifdim\dimen0<\dimen1
    % Figure doesn't fit on current page — page eject approach (v3.23).
    % Cancel parshape so current-page text runs at full width.
    \parshape 1 0pt \linewidth\relax
    \emergencystretch=0pt\relax
    \swarmwrap@activefalse
    \global\let\par\swarmwrap@orig@par
    \everypar{}%
    % Eject to new page
    \newpage
    % Re-establish wrapping on the new page (same as NORMAL path).
    \parshape \swarmwrap@pshape\relax
    \swarmwrap@activetrue
    \global\let\par\swarmwrap@patched@par
    % Re-record figure extent on the NEW page
    \global\swarmwrap@fig@bottom=\pagetotal
    \global\advance\swarmwrap@fig@bottom by \swarmwrap@fh\relax
    \global\swarmwrap@fig@page=\the\c@page\relax
    \emergencystretch=\fontdimen6\font\relax
    \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
    \noindent
    \smash{\rlap{\hskip\swarmwrap@tw@val\hskip14pt\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}}}%
    \wlog{swarmwrap next: DEFERRED (page eject) — remaining=\the\dimen0, fh=\the\swarmwrap@fh, nl=\the\swarmwrap@nl}%
  \else
    % Figure fits — place inline. \noindent suppresses paragraph indent.
    \noindent
    \smash{\rlap{\hskip\swarmwrap@tw@val\hskip14pt\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}}}%
    \wlog{swarmwrap next: NORMAL — tw=\the\swarmwrap@tw, fh=\the\swarmwrap@fh, nl=\the\swarmwrap@nl, remaining=\the\dimen0}%
  \fi
}%
\else
\newcommand{\swarmwrapnext}{%
  \PackageError{swarmwrap}{LuaLaTeX required for wrapping. Text wrapping is not supported on pdfLaTeX/XeLaTeX. Either compile with lualatex, or remove swarmwrap.}{}%
}%
\fi

\endinput
