% swarmwrap.sty — Right-side float wrapper for the Swarm toolkit (v3.12)
%
% Text wrapping using \parshape applied by \swarmwrapnext command.
% Built from scratch after all 9 existing LaTeX wrapping packages failed QA.
%
% Usage:
%   \usepackage{swarmwrap}
%
%   % Simple figure (single content box):
%   \begin{swarmwrap}%
%     \includegraphics[width=3cm]{photo}%
%   \end{swarmwrap}%
%   \swarmwrapnext
%   Paragraph text wraps around the figure.
%
%   % Multi-line content (figure + caption):
%   \begin{swarmwrap}%
%     \begin{minipage}[t]{3cm}
%       \centering
%       \includegraphics[width=\linewidth]{photo}
%       \captionof{figure}{Caption.}
%     \end{minipage}%
%   \end{swarmwrap}%
%   \swarmwrapnext
%   Paragraph text wraps around the figure.
%
%   % Custom page-break penalty (discourage breaks in wrapped zone):
%   \swarmwrappenalty{500}  % default is 10000 (very discouraged)
%
% Zero arguments. Width and height are auto-detected from the rendered
% content box. The user controls the content width explicitly (e.g.,
% \includegraphics[width=3cm] or \begin{minipage}[t]{3cm}).
% Right-side wrapping only. Left-wrap removed in v3.0 (scope reduction).
%
% Requirements: LuaLaTeX (errors out on pdfLaTeX/XeLaTeX)
%
% ── Known Limitations ─────────────────────────────────────────────────
%
% 1. Ghost narrowing on continuation pages:
%    When the wrapped paragraph spans a page break, TeX's parshape
%    persists across the page boundary but the figure does not (it is
%    placed via \smash{\rlap{...}} which is page-local). Continuation
%    lines on the next page remain narrowed even though no figure is
%    beside them. This is cosmetic only — no text overlaps the figure.
%    Mitigation: \swarmwrappenalty{N} inserts a penalty at the
%    boundary to discourage TeX from breaking there (default: 10000).
%    Affects only very long paragraphs that span page breaks.
%
% 2. Parshape leak into list items:
%    If \swarmwrapnext is used inside a list item (\item), the parshape
%    leaks into subsequent \item paragraphs within the same list
%    environment. Items 2+ will be narrowed even without swarmwrap.
%    Workaround: use swarmwrap BEFORE the list, not inside it.
%
% 3. Deferred figure placement:
%    When the figure doesn't fit on the current page, it is deferred to
%    the top of the next page via \afterpage as a centered figure.
%    Text on the current page flows at full width (no parshape applied).
%    This avoids both overlap and ghost narrowing in the deferred case.
%    Detection uses \pagegoal - \pagetotal.
%
% ── Changelog ───────────────────────────────────────────────────────
%
% v3.12: Fixed emergencystretch leak. The NORMAL branch sets
%   \emergencystretch to \fontdimen6\font (~5pt) for narrowed lines,
%   but TeX does not auto-reset it between paragraphs. This caused
%   subsequent (non-wrapped) paragraphs to inherit elevated
%   emergencystretch, producing slightly looser line breaks. Now
%   the post_linebreak_filter callback resets emergencystretch to 0pt
%   after processing each wrapped paragraph.
%
% v3.11: Fixed deferred figure placement. v3.10's overlaid deferred
%   figure caused text-figure overlap on the next page (full-width text
%   after parshape expiration collided with the overlaid figure). Now
%   when the figure doesn't fit, parshape is NOT applied (text flows at
%   full width) and the figure is deferred as a centered block via
%   \afterpage. Eliminates overlap, ghost narrowing, and clipping.
%
% v3.10: Deferred figure placement (overlaid via \afterpage). Re-added
%   afterpage dependency.
%
% v3.7: Reduced figure height padding from \baselineskip (13.6pt) to 4pt.
%   Eliminates 1 extra narrowed line below each figure that had no
%   figure beside it (visible empty strip).
%
% v3.6: Added \swarmwrappenalty{N} option (default 10000). Uses
%   LuaTeX post_linebreak_filter to insert a penalty at the boundary
%   between the last narrowed line and the first full-width line,
%   discouraging page breaks that cause ghost narrowing.
%
% v3.5: Non-LuaLaTeX compilation produces hard error (was silent fallback).
%   \swarmwrapnext errors on non-LuaLaTeX (was \relax).
%
% v3.4: Page-eject fallback replaces zero-height vbox. No more text-
%   figure overlap on page breaks.

\ProvidesPackage{swarmwrap}[2026/05/19 v3.12 Custom float wrapper]

\RequirePackage{graphicx}
\RequirePackage{ifluatex}
\RequirePackage{afterpage}

\newsavebox{\swarmwrap@box}
\newdimen\swarmwrap@fw       % figure width (auto-detected from box)
\newdimen\swarmwrap@fh       % figure height (auto-detected from box)
\newdimen\swarmwrap@tw       % text width (computed for parshape)
\newcount\swarmwrap@nl       % number of parshape lines (wrapped)
\newcount\swarmwrap@loop@cnt % loop counter
\newif\ifswarmwrap@luatex

\ifluatex \swarmwrap@luatextrue \else \swarmwrap@luatexfalse \fi

% Global macros to persist values across the environment group boundary.
\newcommand{\swarmwrap@fw@val}{0pt}  % figure width for parshape
\newcommand{\swarmwrap@fh@val}{0pt}  % figure height for page break

% ── Penalty control ──────────────────────────────────────────────────
% \swarmwrappenalty{N}: set the penalty inserted at the boundary between
% the last narrowed parshape line and the first full-width line.
% Default: 10000 (strongly discourage page break at boundary).
% Set to 0 to allow breaks (no penalty). Set to -10000 to force a break.
\newcount\swarmwrap@penalty
\swarmwrap@penalty=10000

\newcommand{\swarmwrappenalty}[1]{%
  \swarmwrap@penalty=#1\relax
}

% Lua-readable register for the current wrapped text width.
% Set by \swarmwrapnext; read by the post_linebreak_filter callback.
\newdimen\swarmwrap@tw@lua
\swarmwrap@tw@lua=0pt

% ── Lua callback: post_linebreak_filter ───────────────────────────────
% When a paragraph is broken into lines, this callback checks whether
% a parshape narrowing is active (swarmwrap@tw@lua > 0). If so, it
% identifies the boundary between the last narrowed line and the first
% full-width line, and inserts a penalty node there. This discourages
% TeX from breaking the page at the transition point, which would cause
% ghost narrowing on the continuation page.

\ifswarmwrap@luatex
\directlua{
  function swarmwrap_post_lb(head, groupcode)
    local tw_sp = tex.dimen["swarmwrap@tw@lua"]
    if tw_sp <= 0 then
      return head
    end
    local penalty_val = tex.count["swarmwrap@penalty"]
    if penalty_val == 0 then
      return head
    end
    -- Convert skip to scaled points for comparison
    local tw_val = tw_sp / 65536.0
    local tol = 3.0  -- pt tolerance
    local narrow_width_max = tw_val + tol
    -- Walk the node list to find the last narrowed hlist
    local last_narrow = nil
    local current = head
    while current do
      if current.id == 0 then  -- hlist node (a broken line)
        local lw = current.width / 65536.0
        if lw <= narrow_width_max and lw > 0 then
          last_narrow = current
        end
      end
      current = current.next
    end
    if last_narrow then
      local p = node.new(node.id("penalty"))
      p.penalty = penalty_val
      node.insert_after(head, last_narrow, p)
    end
    -- Reset emergencystretch to prevent leaking into subsequent paragraphs.
    -- swarmwrap sets it to \fontdimen6\font (~5pt) in the NORMAL branch,
    -- but TeX does not auto-reset it between paragraphs.
    tex.dimen["emergencystretch"] = 0
    return head
  end
  luatexbase.add_to_callback("post_linebreak_filter",
    swarmwrap_post_lb, "swarmwrap: penalty at parshape boundary")
}
\fi

% ── Environment: capture content into a savebox (zero args) ────────────
% Content sets its natural width via explicit sizing:
%   - \includegraphics[width=3cm]{photo}  → box width = 3cm
%   - \begin{minipage}[t]{3cm}...        → box width = 3cm
% Width and height are measured from the rendered box after closing.

\newenvironment{swarmwrap}{%
  \ifswarmwrap@luatex
    \begin{lrbox}{\swarmwrap@box}%
  \else
    \PackageError{swarmwrap}{LuaLaTeX required for wrapping}{}%
  \fi
}{%
  \ifswarmwrap@luatex
    \end{lrbox}%
    % CRITICAL: Make the savebox global so it survives the group exit.
    \global\setbox\swarmwrap@box=\box\swarmwrap@box
    % Auto-detect width from rendered box
    \swarmwrap@fw=\wd\swarmwrap@box
    \xdef\swarmwrap@fw@val{\the\swarmwrap@fw}%
    % Auto-detect height from rendered box (+ small gap for visual spacing)
    \swarmwrap@fh=\ht\swarmwrap@box
    \advance\swarmwrap@fh by \dp\swarmwrap@box
    \advance\swarmwrap@fh by 4pt
    \xdef\swarmwrap@fh@val{\the\swarmwrap@fh}%
  \fi
}

% ── Helper: place figure centered (used for deferred placement) ──────
% Uses explicit \hbox centering instead of \begin{center} because the
% latter doesn't work reliably inside \afterpage (which expands in a
% special vertical mode context where \centering may not take effect).
\newcommand{\swarmwrap@place@centered}{%
  \par\vspace{\medskipamount}%
  \noindent\hb@xt@\linewidth{\hss\copy\swarmwrap@box\hss}%
  \par\vspace{\medskipamount}%
}

% ── \swarmwrapnext: compute parshape and place figure ──────────────────
% All computation happens here so \linewidth is captured at the
% correct location (inside multicol, itemize, etc.).
%
% Figure placement strategy (v3.11):
%   1. Compute parshape from full figure height (text always stays).
%   2. Check if figure fits: \pagegoal - \pagetotal >= figure height.
%   3. If fits → place inline with \smash{\rlap{}}.
%   4. If doesn't fit → NO parshape (text at full width), defer
%      centered figure to top of next page via \afterpage.
%      This avoids overlap (overlaid figure on next page would collide
%      with full-width continuation text after parshape expires) and
%      ghost narrowing (no parshape = no leak across page break).

\ifswarmwrap@luatex
\newcommand{\swarmwrapnext}{%
  % ── Shared computation: text width and wrapped line count ───────
  \swarmwrap@fw=\swarmwrap@fw@val\relax
  \swarmwrap@tw=\linewidth
  \advance\swarmwrap@tw by -\swarmwrap@fw
  \advance\swarmwrap@tw by -14pt
  \swarmwrap@nl=0
  \swarmwrap@fh=\swarmwrap@fh@val\relax
  \dimen0=\swarmwrap@fh
  \loop
    \advance\swarmwrap@nl by 1
    \advance\dimen0 by -\baselineskip
  \ifdim\dimen0>0pt \repeat
  \xdef\swarmwrap@tw@val{\the\swarmwrap@tw}%
  % Set Lua-readable dimension for post_linebreak_filter callback
  \global\swarmwrap@tw@lua=\swarmwrap@tw\relax
  % ── Build parshape string ──────────────────────────────────────
  \xdef\swarmwrap@pshape{\the\numexpr\swarmwrap@nl+1\relax\space}%
  \swarmwrap@loop@cnt=\swarmwrap@nl
  \loop
    \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\swarmwrap@tw\space}%
    \advance\swarmwrap@loop@cnt by -1
  \ifnum\swarmwrap@loop@cnt>0 \repeat
  \xdef\swarmwrap@pshape{\swarmwrap@pshape 0pt \the\linewidth\space}%
  % ── Figure placement: inline or deferred ───────────────────────
  % Check remaining space on current page.
  \dimen0=\pagegoal
  \advance\dimen0 by -\pagetotal
  \dimen1=\swarmwrap@fh@val\relax
  \ifdim\dimen0<\dimen1
    % Figure doesn't fit — NO wrapping, defer centered figure to next page.
    % Don't apply parshape: text flows at full width on current page.
    % Disable penalty callback (no narrow lines to find).
    \global\swarmwrap@tw@lua=0pt\relax
    \noindent
    \afterpage{\swarmwrap@place@centered}%
    \wlog{swarmwrap next: DEFERRED CENTERED — remaining=\the\dimen0, fh=\the\dimen1, nl=\the\swarmwrap@nl}%
  \else
    % Figure fits — apply parshape and place inline overlay.
    % emergencystretch absorbs overfull hbox on narrowed parshape lines
    \emergencystretch=\fontdimen6\font\relax
    \noindent
    \parshape \swarmwrap@pshape\relax
    \smash{\rlap{\hskip\swarmwrap@tw@val\hskip14pt\raise\dimexpr\ht\strutbox-\ht\swarmwrap@box\relax\hbox{\copy\swarmwrap@box}}}%
    \wlog{swarmwrap next: NORMAL — tw=\the\swarmwrap@tw, fh=\the\swarmwrap@fh, nl=\the\swarmwrap@nl, remaining=\the\dimen0}%
  \fi
}%
\else
\newcommand{\swarmwrapnext}{%
  \PackageError{swarmwrap}{LuaLaTeX required for wrapping. Text wrapping is not supported on pdfLaTeX/XeLaTeX. Either compile with lualatex, or remove swarmwrap.}{}%
}%
\fi

\endinput
