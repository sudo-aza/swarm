% =============================================================================
% swarmperf.sty — The "Performance" Theme for the LaTeX Helper Swarm  (v1.2)
%
% A minimal, fast-to-compile document theme optimized for:
%   - Maximum compilation speed (works with pdfLaTeX, XeLaTeX, LuaLaTeX)
%   - Zero external dependencies (no Pygments, no fontspec, no shell-escape)
%   - Clean, professional typography with minimal overhead
%
% NOTE: The performance advantage is compilation SPEED (3-9x faster than the
% beautiful theme), not PDF size. Font embedding dominates PDF size, so the
% output files are comparable in kilobytes.
%
% Design philosophy: every package must earn its place. Heavy packages like
% TikZ, fontspec, microtype, tcolorbox, and minted are deliberately excluded
% to minimize load and compilation time. Uses `listings` instead of `minted`
% for code highlighting, `fancyhdr` for headers/footers, and basic LaTeX
% environments instead of tcolorbox for blocks.
%
% NOTE: titlesec is NOT used due to known incompatibility with LuaLaTeX in
% TeX Live 2026. Standard LaTeX sectioning commands are used instead.
%
% Usage:
%   \documentclass[11pt, a4paper]{article}      % or scrartcl
%   \usepackage{swarmperf}
%
% Compatible with: pdfLaTeX (fastest), XeLaTeX, LuaLaTeX
% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{swarmperf}[2026/05/15 v1.2 LaTeX Helper Swarm — Performance Theme]

% ── Core packages (minimal set) ──────────────────────────────────────────────
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{mathtools}
\RequirePackage{booktabs}
\RequirePackage{caption}
\RequirePackage{float}
\RequirePackage{placeins}
\RequirePackage{enumitem}
\RequirePackage{fancyhdr}
\RequirePackage{listings}
\RequirePackage{hyperref}

% ── Color Palette (minimal — 7 colors) ──────────────────────────────────────

\definecolor{spDark}{HTML}{2C3E50}      % Dark blue-gray (headings, titles)
\definecolor{spAccent}{HTML}{3498DB}     % Bright blue (links, accents)
\definecolor{spGray}{HTML}{7F8C8D}      % Medium gray (subtle elements)
\definecolor{spLight}{HTML}{F2F3F4}      % Light gray (backgrounds)
\definecolor{spCodeBg}{HTML}{F8F9FA}    % Very light gray (code background)
\definecolor{spGreen}{HTML}{27AE60}      % Green (tip blocks)
\definecolor{spOrange}{HTML}{E67E22}     % Orange (warning blocks)

% ── Page Layout ─────────────────────────────────────────────────────────────
% Use geometry for simple, reliable page setup. Works with article, scrartcl, etc.

\RequirePackage[
  a4paper,
  left   = 2.5cm,
  right  = 2.5cm,
  top    = 2.5cm,
  bottom = 2.5cm,
  headheight = 14pt,
]{geometry}

% ── Paragraph spacing ───────────────────────────────────────────────────────
\parskip  = 0.5ex plus 0.2ex
\parindent = 0pt

% ── \subtitle compatibility ────────────────────────────────────────────────
% \subtitle is built into KOMA-Script but not in standard article class.
% Provide a definition so it works with both article and scrartcl.

\makeatletter
\providecommand{\subtitle}[1]{\gdef\@subtitle{#1}}
\providecommand{\@subtitle}{}
\makeatother

% ── Section Heading Styling ────────────────────────────────────────────────
% NOTE: titlesec is NOT used — it has a known incompatibility with LuaLaTeX
% in TeX Live 2026 (breaks \@xdblarg). Standard LaTeX sectioning is used.
% \sectionfont/\subsectionfont are KOMA-only — override numbering color instead.

% NOTE: Do NOT put \textcolor or \bfseries inside \thesection/\thesubsection.
% These counter representations are used in moving arguments (TOC, headers,
% bookmarks, \ref) where LaTeX may uppercase text, breaking color names.
% Instead, keep plain numbers and apply color at the display level.

% ── Title Page ──────────────────────────────────────────────────────────────
% Simple, fast title page using basic LaTeX commands. No TikZ.
% Provides \swarmtitlepage (unified API) with \maketitle as backward-compat alias.

\makeatletter
\newcommand{\swarmtitlepage}{%
  \begin{titlepage}
    \vspace*{2cm}
    \begin{center}
      {\LARGE\sffamily\bfseries\color{spDark}\@title\par}
      \vspace{0.4em}
      {\large\color{spAccent}\rule{0.6\textwidth}{0.8pt}\par}
      \vspace{0.6em}
      {\large\sffamily\color{spGray}\@subtitle\par}
    \end{center}

    \vfill

    \begin{center}
      {\normalsize\color{spGray}\@author\par}
      \vspace{0.5em}
      {\small\color{spGray}\@date\par}
    \end{center}

    \vfill
  \end{titlepage}
}
% Backward compatibility: \maketitle delegates to \swarmtitlepage
\renewcommand{\maketitle}{\swarmtitlepage}
\makeatother

% ── Headers & Footers ──────────────────────────────────────────────────────
% Simple header/footer via fancyhdr.

\pagestyle{fancy}
\fancyhf{}

\fancyhead[L]{\footnotesize\sffamily\color{spGray}\leftmark}
\fancyhead[R]{\footnotesize\sffamily\color{spGray}\@title}
\renewcommand{\headrulewidth}{0.4pt}

\fancyfoot[L]{\footnotesize\color{spGray}\@date}
\fancyfoot[R]{\footnotesize\sffamily\bfseries\color{spAccent}\thepage}
\renewcommand{\footrulewidth}{0pt}

% ── Table Styling ──────────────────────────────────────────────────────────
% Clean booktabs tables with minimal decoration.
% Provides \swarmtoprule/\swarmmidrule/\swarmbottomrule (unified API)
% with \perftoprule/\perfmidrule/\perfbottomrule as backward-compat aliases.

\newcommand{\swarmtoprule}{\toprule}
\newcommand{\swarmmidrule}{\midrule}
\newcommand{\swarmbottomrule}{\bottomrule}
\newcommand{\perftoprule}{\swarmtoprule}
\newcommand{\perfmidrule}{\swarmmidrule}
\newcommand{\perfbottomrule}{\swarmbottomrule}

\captionsetup{
  font      = {sf, small},
  labelfont = {bf, color=spAccent},
  labelsep  = quad,
  skip      = 6pt,
  format    = plain,
  indention = 0pt,
}

% ── Code Listings (listings — zero external deps) ───────────────────────────

\lstset{
  basicstyle       = \ttfamily\small,
  keywordstyle     = \bfseries,
  commentstyle     = \itshape,
  stringstyle      = ,
  numberstyle      = \tiny,
  numbers          = left,
  numbersep        = 8pt,
  breaklines       = true,
  frame            = single,
  rulecolor        = \color{spGray!40},
  backgroundcolor  = \color{spCodeBg},
  captionpos       = b,
  tabsize          = 4,
  showstringspaces = false,
  columns          = fullflexible,
  keepspaces       = true,
  xleftmargin      = 2em,
  framexleftmargin = 1.5em,
  aboveskip        = 1em,
  belowskip        = 0.5em,
}

% Named listing environment with a title
\lstnewenvironment{codelisting}[2][Python]{%
  \lstset{language=#1, title={\sffamily\small\bfseries #2}}%
}{}

% Inline code
\newcommand{\code}[1]{%
  \colorbox{spCodeBg}{\texttt{\small\color{spDark}{#1}}}%
}
% For code with underscores/special chars: \codeesc{some_function()}
\newcommand{\codeesc}[1]{%
  \colorbox{spCodeBg}{\texttt{\small\color{spDark}{\detokenize{#1}}}}%
}

% ── Block Environments (lightweight — no tcolorbox) ─────────────────────────
% Simple blocks using minipage. Minimal compilation overhead.

\newenvironment{noteblock}[1][Note]{%
  \par\vspace{0.6em}%
  \noindent\hspace{0pt}%
  \color{spAccent}\rule[-3pt]{3pt}{1.2em}%
  \begin{minipage}[t]{\dimexpr\linewidth-7pt\relax}%
    \hspace{6pt}%
    {\sffamily\small\bfseries\color{spAccent}#1}%
    \par\vspace{0.2em}%
}{%
  \end{minipage}%
  \par\vspace{0.4em}%
}

\newenvironment{tipblock}[1][Tip]{%
  \par\vspace{0.6em}%
  \noindent\hspace{0pt}%
  \color{spGreen}\rule[-3pt]{3pt}{1.2em}%
  \begin{minipage}[t]{\dimexpr\linewidth-7pt\relax}%
    \hspace{6pt}%
    {\sffamily\small\bfseries\color{spGreen}#1}%
    \par\vspace{0.2em}%
}{%
  \end{minipage}%
  \par\vspace{0.4em}%
}

\newenvironment{warningblock}[1][Warning]{%
  \par\vspace{0.6em}%
  \noindent\hspace{0pt}%
  \color{spOrange}\rule[-3pt]{3pt}{1.2em}%
  \begin{minipage}[t]{\dimexpr\linewidth-7pt\relax}%
    \hspace{6pt}%
    {\sffamily\small\bfseries\color{spOrange}#1}%
    \par\vspace{0.2em}%
}{%
  \end{minipage}%
  \par\vspace{0.4em}%
}

% ── Math Theorem Environments ───────────────────────────────────────────────
% API-compatible with swarmbeauty/swarmmin: \begin{theorem}{name}{label}
% Both arguments are mandatory (matches \newtcbtheorem from tcolorbox).
% The {label} arg is accepted but unused — users should add \label{} manually.
% Numbered within \section.

\newcounter{sptheorem}[section]
\newcounter{spdefinition}[section]
\newcounter{splemma}[section]
\renewcommand{\thesptheorem}{\thesection.\arabic{sptheorem}}
\renewcommand{\thespdefinition}{\thesection.\arabic{spdefinition}}
\renewcommand{\thesplemma}{\thesection.\arabic{splemma}}

\newenvironment{theorem}[2]{%
  \refstepcounter{sptheorem}%
  \par\vspace{0.5em}%
  \noindent\textbf{Theorem~\thesptheorem}\ifx\\#1\\\else\space(#1)\fi.%
  \space\itshape\ignorespaces
}{\par\vspace{0.5em}\upshape}

\newenvironment{definition}[2]{%
  \refstepcounter{spdefinition}%
  \par\vspace{0.5em}%
  \noindent\textbf{Definition~\thespdefinition}\ifx\\#1\\\else\space(#1)\fi.%
  \space\itshape\ignorespaces
}{\par\vspace{0.5em}\upshape}

\newenvironment{lemma}[2]{%
  \refstepcounter{splemma}%
  \par\vspace{0.5em}%
  \noindent\textbf{Lemma~\thesplemma}\ifx\\#1\\\else\space(#1)\fi.%
  \space\itshape\ignorespaces
}{\par\vspace{0.5em}\upshape}

% ── Hyperlink Styling ──────────────────────────────────────────────────────

\hypersetup{
  colorlinks = true,
  linkcolor  = spDark,
  urlcolor   = spAccent,
  citecolor  = spAccent,
  filecolor  = spAccent,
}

% ── Itemize / Enumerate ─────────────────────────────────────────────────────

\setlist[itemize]{
  label      = \textcolor{spAccent}{\textbullet},
  itemsep    = 4pt,
  leftmargin = 1.2em,
  parsep     = 0pt,
}

\setlist[enumerate]{
  label      = \textcolor{spAccent}{\bfseries\arabic*.},
  itemsep    = 4pt,
  leftmargin = 1.5em,
  parsep     = 0pt,
}

% ── Utility Commands ───────────────────────────────────────────────────────

\newcommand{\hltext}[1]{\textcolor{spAccent}{\textbf{#1}}}

\newcommand{\colorrule}{%
  \par\noindent\textcolor{spAccent}{\rule{\textwidth}{0.4pt}}\par\vspace{0.5em}%
}

% ── Footnote Styling ───────────────────────────────────────────────────────

\renewcommand{\thefootnote}{\textcolor{spAccent}{\arabic{footnote}}}

% ── Bibliography (optional) ────────────────────────────────────────────────
% Users should load biblatex themselves:
%   \usepackage[backend=biber, style=numeric]{biblatex}

% ── END ────────────────────────────────────────────────────────────────
\endinput
